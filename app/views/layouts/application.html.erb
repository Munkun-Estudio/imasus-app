<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "IMASUS App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="IMASUS App">
    <meta name="mobile-web-app-capable" content="yes">
    <% if content_for?(:meta_description) %>
      <meta name="description" content="<%= strip_tags(content_for(:meta_description)).squish %>">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "trix", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-stone-100" data-controller="mobile-menu">
    <%# Mobile header — visible below lg breakpoint %>
    <header class="fixed inset-x-0 top-0 z-40 flex items-center justify-between border-b border-imasus-dark-green/10 bg-white px-4 py-3 lg:hidden">
      <a href="<%= root_path %>" class="text-lg font-bold text-imasus-dark-green">IMASUS</a>
      <div class="flex items-center gap-2">
        <div data-locale-switcher-position="mobile-header">
          <%= render "shared/locale_switcher" %>
        </div>
        <button type="button"
                data-mobile-menu-target="toggle"
                data-action="mobile-menu#toggle"
                class="rounded-lg p-2 text-imasus-dark-green/70 hover:bg-imasus-mint/10"
                aria-label="<%= t("nav.toggle_menu") %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </header>

    <%# Mobile overlay backdrop %>
    <div data-mobile-menu-target="backdrop"
         data-action="click->mobile-menu#close"
         class="fixed inset-0 z-30 bg-black/30 hidden lg:hidden"></div>

    <%# Sidebar %>
    <aside data-mobile-menu-target="sidebar"
           class="fixed inset-y-0 left-0 z-50 w-64 border-r border-imasus-dark-green/10 bg-white
                  -translate-x-full transition-transform duration-200 ease-in-out
                  lg:translate-x-0 lg:z-auto">
      <%= render "shared/sidebar" %>
    </aside>

    <%# Main content area %>
    <div class="flex min-h-screen flex-col pt-14 lg:ml-64 lg:pt-0">
      <%# Top-right locale switcher — visible to logged-in and logged-out users alike. %>
      <div data-locale-switcher-position="top-right"
           class="hidden lg:flex absolute right-6 top-4 z-30 items-center gap-1">
        <%= render "shared/locale_switcher" %>
      </div>

      <main class="flex-1">
        <%= yield %>
      </main>

      <%= render "shared/footer" %>
    </div>

    <%# Modal slot for Turbo Frame modals (delete confirmations, etc.) %>
    <%= turbo_frame_tag "modal" %>

    <%# Preview slot for Turbo Frame previews (material preview sidebar, etc.) %>
    <%= turbo_frame_tag "preview" %>
  </body>
</html>
