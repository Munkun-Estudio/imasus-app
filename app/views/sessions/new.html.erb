<h1><%= t("sessions.new.title", default: "Sign in") %></h1>

<% if flash[:alert] %>
  <p role="alert"><%= flash[:alert] %></p>
<% end %>

<%= form_with url: session_path, local: true do |f| %>
  <div>
    <%= f.label :email, t("sessions.new.email", default: "Email") %>
    <%= f.email_field :email, required: true, autofocus: true, autocomplete: "username" %>
  </div>

  <div>
    <%= f.label :password, t("sessions.new.password", default: "Password") %>
    <%= f.password_field :password, required: true, autocomplete: "current-password" %>
  </div>

  <%= f.submit t("sessions.new.submit", default: "Sign in") %>
<% end %>

<p><%= link_to t("sessions.new.forgot_password", default: "Forgot your password?"), new_password_reset_path %></p>
