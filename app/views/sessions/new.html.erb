<div class="<%= form_page_classes %>">
  <div class="<%= form_card_classes %>">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-imasus-dark-green/45"><%= t("sessions.new.eyebrow", default: "IMASUS Access") %></p>
    <h1 class="mt-3 text-3xl font-bold text-imasus-dark-green"><%= t("sessions.new.title", default: "Sign in") %></h1>
    <p class="mt-3 text-base leading-7 text-stone-700"><%= t("sessions.new.lead", default: "Use your IMASUS account to continue to workshops, invitations, and collaborative work.") %></p>

    <% if flash[:alert] %>
      <p role="alert" class="<%= form_error_box_classes %> mt-6"><%= flash[:alert] %></p>
    <% end %>

    <%= form_with url: session_path, local: true, class: "mt-8 space-y-5" do |f| %>
      <div>
        <%= f.label :email, t("sessions.new.email", default: "Email"), class: form_label_classes %>
        <%= f.email_field :email, required: true, autofocus: true, autocomplete: "username", class: form_input_classes %>
      </div>

      <div>
        <%= f.label :password, t("sessions.new.password", default: "Password"), class: form_label_classes %>
        <%= f.password_field :password, required: true, autocomplete: "current-password", class: form_input_classes %>
      </div>

      <%= f.submit t("sessions.new.submit", default: "Sign in"), class: form_primary_button_classes %>
    <% end %>

    <p class="mt-5">
      <%= link_to t("sessions.new.forgot", default: "Forgot your password?"),
                  new_password_reset_path,
                  class: form_secondary_link_classes %>
    </p>
  </div>
</div>
