<% content_for :title, t(".title") %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <header class="max-w-3xl">
    <h1 class="text-3xl font-bold text-imasus-dark-green"><%= t(".title") %></h1>
  </header>

  <div class="mt-10 space-y-12 max-w-3xl">
    <% @grouped.each do |type, bookmarks| %>
      <section>
        <h2 class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
          <%= t(".groups.#{type.underscore}") %>
        </h2>

        <% if bookmarks.any? %>
          <ul class="mt-4 divide-y divide-imasus-dark-green/10">
            <% bookmarks.each do |bookmark| %>
              <li id="bookmark-row-<%= bookmark.id %>"
                  class="flex items-start justify-between gap-4 py-3">
                <div class="min-w-0">
                  <%= link_to bookmark.label,
                        bookmark.url,
                        class: "block truncate text-sm font-medium text-imasus-dark-green hover:underline" %>
                  <p class="mt-0.5 truncate text-xs text-imasus-dark-green/50">
                    <%= bookmark.url %>
                  </p>
                </div>
                <%= form_with url: bookmark_path(bookmark), method: :delete,
                              data: { turbo_stream: "" },
                              class: "shrink-0" do |f| %>
                  <%= f.hidden_field :context, value: "index" %>
                  <button type="submit"
                          aria-label="<%= t(".remove") %>"
                          title="<%= t(".remove") %>"
                          class="rounded-full p-1 text-imasus-dark-green/30 transition hover:bg-imasus-red/10 hover:text-imasus-red">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
                    </svg>
                  </button>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="mt-4 text-sm text-imasus-dark-green/50">
            <%= t(".empty.#{type.underscore}",
                  default: t(".empty.default"),
                  link_start: "",
                  link_end: "") %>
          </p>
        <% end %>
      </section>
    <% end %>
  </div>
</div>
