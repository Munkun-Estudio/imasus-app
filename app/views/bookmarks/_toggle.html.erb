<%# locals: (bookmark:, bookmarkable_type:, resource_key:, label:, url:, dom_id:) %>
<span id="<%= dom_id %>">
  <% if bookmark %>
    <%= form_with url: bookmark_path(bookmark), method: :delete,
                  data: { turbo_stream: "" },
                  class: "inline" do %>
      <button type="submit"
              title="<%= t("bookmarks.unsave") %>"
              aria-label="<%= t("bookmarks.unsave") %>"
              class="bookmark-toggle saved inline-flex items-center justify-center rounded-full p-1 text-imasus-dark-green transition hover:bg-imasus-dark-green/10">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
          <path fill-rule="evenodd" d="M6.32 2.577a49.255 49.255 0 0 1 11.36 0c1.497.174 2.57 1.46 2.57 2.93V21a.75.75 0 0 1-1.085.67L12 18.089l-7.165 3.583A.75.75 0 0 1 3.75 21V5.507c0-1.47 1.073-2.756 2.57-2.93Z" clip-rule="evenodd"/>
        </svg>
      </button>
    <% end %>
  <% else %>
    <%= form_with url: bookmarks_path, scope: :bookmark,
                  data: { turbo_stream: "" },
                  class: "inline" do |f| %>
      <%= f.hidden_field :bookmarkable_type, value: bookmarkable_type %>
      <%= f.hidden_field :resource_key,      value: resource_key %>
      <%= f.hidden_field :label,             value: label %>
      <%= f.hidden_field :url,               value: url %>
      <button type="submit"
              title="<%= t("bookmarks.save") %>"
              aria-label="<%= t("bookmarks.save") %>"
              class="bookmark-toggle inline-flex items-center justify-center rounded-full p-1 text-imasus-dark-green/40 transition hover:bg-imasus-dark-green/10 hover:text-imasus-dark-green">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z"/>
        </svg>
      </button>
    <% end %>
  <% end %>
</span>
