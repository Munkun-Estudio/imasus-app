<%= turbo_frame_tag "modal" do %>
  <div data-controller="modal"
       data-action="keydown.esc@window->modal#close click->modal#backdrop"
       class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
    <div role="dialog"
         aria-modal="true"
         aria-labelledby="confirm-delete-title"
         tabindex="-1"
         data-modal-target="dialog"
         class="w-full max-w-md rounded-xl bg-white p-6 shadow-xl">
      <h2 id="confirm-delete-title" class="text-lg font-semibold text-imasus-dark-green">
        <%= t("glossary_terms.actions.delete_confirm_title") %>
      </h2>
      <p class="mt-2 text-sm text-imasus-dark-green/80">
        <%= t("glossary_terms.actions.delete_confirm_body", term: glossary_term.term) %>
      </p>

      <div class="mt-6 flex items-center justify-end gap-2">
        <button type="button"
                data-action="modal#close"
                data-role="cancel-delete-glossary-term"
                class="rounded-md border border-imasus-dark-green/20 px-4 py-2 text-sm font-medium text-imasus-dark-green hover:bg-imasus-mint/20">
          <%= t("glossary_terms.form.cancel") %>
        </button>

        <%= button_to t("glossary_terms.actions.delete_confirm_submit"),
              glossary_term_path(glossary_term.slug),
              method: :delete,
              data: { role: "confirm-delete-glossary-term" },
              class: "rounded-md bg-imasus-red px-4 py-2 text-sm font-semibold text-white hover:bg-imasus-red/90" %>
      </div>
    </div>
  </div>
<% end %>
