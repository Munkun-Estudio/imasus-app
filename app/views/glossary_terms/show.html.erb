<% content_for :title, "#{@glossary_term.term} — #{t("glossary_terms.index.title")}" %>
<% content_for :head do %>
  <meta name="description" content="<%= t("glossary_terms.show.meta_description", term: @glossary_term.term) %>">
<% end %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <div class="max-w-2xl">
    <%= link_to t("glossary_terms.show.back_to_index"), glossary_terms_path,
          class: "inline-flex items-center text-sm font-semibold text-imasus-dark-green/70 hover:text-imasus-dark-green" %>

    <header class="mt-6 flex flex-wrap items-start justify-between gap-4">
      <div class="flex items-start gap-2">
        <h1 class="text-4xl font-bold text-imasus-dark-green"><%= @glossary_term.term %></h1>
        <%= bookmark_toggle(
              bookmarkable_type: "GlossaryTerm",
              resource_key:      @glossary_term.id.to_s,
              label:             @glossary_term.term,
              url:               glossary_term_path(@glossary_term)) %>
      </div>
        <p class="mt-2 text-sm">
          <span class="sr-only"><%= t("glossary_terms.show.category_label") %>:</span>
          <span data-glossary-category
                class="inline-flex items-center rounded-full bg-imasus-light-pink/60 px-3 py-1 text-xs font-medium text-imasus-dark-green">
            <%= t("glossary_terms.categories.#{@glossary_term.category}") %>
          </span>
        </p>
      </div>

      <% if curator? %>
        <div class="flex shrink-0 items-start gap-2">
          <%= link_to t("glossary_terms.actions.edit"),
                edit_glossary_term_path(@glossary_term.slug),
                data: { role: "edit-glossary-term" },
                class: "rounded-md border border-imasus-dark-green/20 px-3 py-1.5 text-sm font-medium text-imasus-dark-green hover:bg-imasus-mint/20" %>
          <%= link_to t("glossary_terms.actions.delete"),
                delete_confirmation_glossary_term_path(@glossary_term.slug),
                data: { role: "delete-glossary-term", turbo_frame: "modal" },
                class: "rounded-md border border-imasus-red/40 px-3 py-1.5 text-sm font-medium text-imasus-red hover:bg-imasus-red/10" %>
        </div>
      <% end %>
    </header>

    <div class="prose prose-stone mt-8">
      <p><%= @glossary_term.definition %></p>
    </div>

    <% examples = @glossary_term.examples %>
    <% if examples.is_a?(Array) && examples.any? %>
      <section class="mt-10">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-imasus-dark-green/70">
          <%= t("glossary_terms.show.examples_label") %>
        </h2>
        <ul class="mt-3 list-disc space-y-2 pl-5 text-imasus-dark-green/80">
          <% examples.each do |example| %>
            <li><%= example %></li>
          <% end %>
        </ul>
      </section>
    <% end %>
  </div>
</div>
