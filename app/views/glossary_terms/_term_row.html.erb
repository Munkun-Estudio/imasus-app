<%= turbo_frame_tag dom_id(term) do %>
  <div class="group -mx-3 rounded-xl px-3 py-4 transition-colors hover:bg-imasus-light-pink/20">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0 flex-1">
        <%= link_to glossary_term_path(term.slug), data: { turbo_frame: "_top" }, class: "block" do %>
          <span class="text-lg font-semibold text-imasus-dark-green">
            <%= term.term %>
          </span>
          <span class="ml-2 inline-flex items-center rounded-full bg-imasus-light-pink/60 px-2 py-0.5 text-xs font-medium text-imasus-dark-green">
            <%= t("glossary_terms.categories.#{term.category}") %>
          </span>
          <% if term.definition.present? %>
            <p class="mt-1 line-clamp-2 text-sm text-imasus-dark-green/70">
              <%= term.definition %>
            </p>
          <% end %>
          <span class="mt-2 flex items-center justify-end gap-1 text-xs font-semibold text-imasus-dark-green opacity-0 transition-opacity group-hover:opacity-100">
            <%= t("glossary_terms.index.know_more") %>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3 w-3">
              <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd"/>
            </svg>
          </span>
        <% end %>
      </div>

      <% if curator? %>
        <div class="flex shrink-0 items-start gap-2">
          <%= link_to t("glossary_terms.actions.edit"),
                edit_glossary_term_path(term.slug),
                data: { role: "edit-glossary-term", turbo_frame: dom_id(term) },
                class: "rounded-md border border-imasus-dark-green/20 px-3 py-1 text-xs font-medium text-imasus-dark-green hover:bg-imasus-mint/20" %>

          <%= link_to t("glossary_terms.actions.delete"),
                delete_confirmation_glossary_term_path(term.slug),
                data: { role: "delete-glossary-term", turbo_frame: "modal" },
                class: "rounded-md border border-imasus-red/40 px-3 py-1 text-xs font-medium text-imasus-red hover:bg-imasus-red/10" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
