<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="width:100%;background:#f6f4ef;margin:0;padding:24px 0;">
  <tr>
    <td align="center" style="padding:0 16px;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="width:100%;max-width:640px;background:#ffffff;border:1px solid #d8e2df;border-radius:20px;overflow:hidden;">
        <tr>
          <td style="padding:18px 24px;background:#f8fbfa;border-bottom:1px solid #d8e2df;">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
              <tr>
                <td valign="top">
                  <p style="margin:0 0 6px;font-size:11px;line-height:1.4;letter-spacing:0.16em;text-transform:uppercase;color:#6a7d7f;font-family:Arial,sans-serif;">
                    IMASUS
                  </p>
                  <p style="margin:0;font-size:20px;line-height:1.3;font-weight:700;color:#1f3d3f;font-family:Arial,sans-serif;">
                    <%= @workshop.title %>
                  </p>
                </td>
                <% if local_assigns[:badge].present? %>
                  <td align="right" valign="top">
                    <span style="display:inline-block;padding:6px 10px;border-radius:999px;background:#afe0c7;color:#1f3d3f;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;font-family:Arial,sans-serif;">
                      <%= badge %>
                    </span>
                  </td>
                <% end %>
              </tr>
            </table>
          </td>
        </tr>

        <tr>
          <td style="padding:28px 24px 12px;">
            <div style="font-family:Arial,sans-serif;color:#1f3d3f;font-size:16px;line-height:1.7;">
              <%= yield %>
            </div>
          </td>
        </tr>

        <tr>
          <td style="padding:18px 24px 24px;border-top:1px solid #e6ece9;">
            <p style="margin:0;font-size:13px;line-height:1.6;color:#5e6f71;font-family:Arial,sans-serif;">
              <%= footer_text %>
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
