<% content_for :title, t("training.index.title") %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <%# Header — matches the show page so navigation reads as one shell. %>
  <div class="mb-8">
    <p class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
      <%= t("training.index.title") %>
    </p>
    <h1 class="mt-2 text-3xl font-bold text-imasus-dark-green">
      <%= @about&.title || t("training.about.heading") %>
    </h1>
  </div>

  <%= render "module_tabs", current: "about", module_slugs: @modules.map(&:slug) %>

  <% if @about %>
    <article class="prose prose-stone max-w-3xl">
      <%= sanitize TrainingModule::Renderer.call(@about.body),
            tags: %w[h1 h2 h3 h4 h5 h6 p br em strong b i a ul ol li blockquote pre code img table thead tbody tr th td hr span sup sub],
            attributes: %w[href src alt loading class id target rel] %>
    </article>
  <% else %>
    <p class="max-w-3xl text-sm leading-relaxed text-imasus-dark-green/60">
      <%= t("training.about.empty") %>
    </p>
  <% end %>
</div>
