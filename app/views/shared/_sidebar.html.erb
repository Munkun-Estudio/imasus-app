<nav aria-label="<%= t("nav.aria_label") %>" class="flex flex-col h-full">
  <div class="px-4 py-6 text-center">
    <a href="<%= root_path %>">
      <%= image_tag "logo.svg", alt: "IMASUS", class: "h-10 inline-block" %>
    </a>
  </div>

  <div data-role="primary-nav" class="flex-1 overflow-y-auto px-4 pt-2 pb-5 space-y-2">
    <%
      items_by_group = nav_items.group_by { |item| item[:group] }
      ordered_groups = [ :hub, :community, :resources ]
    %>
    <% ordered_groups.each do |group| %>
      <% items = items_by_group[group] || [] %>
      <% next if items.empty? %>
      <% if group == :resources %>
        <div data-group="resources" class="space-y-2 pt-2">
          <p data-role="resources-label" class="px-1 text-xs font-medium uppercase tracking-wide text-imasus-dark-green/40">
            <%= t("nav.resources_group") %>
          </p>
          <% items.each do |item| %>
            <%= render "shared/nav_swatch", item: item %>
          <% end %>
        </div>
      <% else %>
        <% items.each do |item| %>
          <%= render "shared/nav_swatch", item: item %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Locale switcher %>
  <div class="border-t border-imasus-dark-green/10 p-4" data-controller="locale-switcher">
    <p class="mb-2 text-xs font-medium uppercase tracking-wide text-imasus-dark-green/40">
      <%= t("locale_switcher.label") %>
    </p>
    <div class="flex flex-wrap gap-1">
      <% I18n.available_locales.each do |loc| %>
        <a href="<%= url_for(locale: loc) %>"
           class="rounded px-2 py-1 text-xs font-bold transition
                  <%= loc.to_s == I18n.locale.to_s ? 'bg-imasus-dark-green text-white' : 'text-imasus-dark-green/50 hover:bg-imasus-dark-green/5' %>">
          <%= loc.to_s.upcase %>
        </a>
      <% end %>
    </div>
  </div>
</nav>
