<nav aria-label="<%= t("nav.aria_label") %>" class="flex flex-col h-full">
  <div class="px-4 py-6 text-center">
    <a href="<%= root_path %>">
      <%= image_tag "logo.svg", alt: "IMASUS", class: "h-10 inline-block" %>
    </a>
  </div>

  <div data-role="primary-nav" class="flex-1 overflow-y-auto px-4 pt-2 pb-5 space-y-2">
    <%
      items_by_group = nav_items.group_by { |item| item[:group] }
      ordered_groups = [ :hub, :community, :resources ]
    %>
    <% ordered_groups.each do |group| %>
      <% items = items_by_group[group] || [] %>
      <% next if items.empty? %>
      <% if group == :resources %>
        <div data-group="resources" class="space-y-2 pt-2">
          <p data-role="resources-label" class="px-1 text-xs font-medium uppercase tracking-wide text-imasus-dark-green/40">
            <%= t("nav.resources_group") %>
          </p>
          <% items.each do |item| %>
            <%= render "shared/nav_swatch", item: item %>
          <% end %>
        </div>
      <% else %>
        <% items.each do |item| %>
          <%= render "shared/nav_swatch", item: item %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Bottom-of-sidebar auth chrome (replaces the old locale switcher slot). %>
  <%= render "shared/user_menu" %>
</nav>
