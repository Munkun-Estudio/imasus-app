<%
  sidebar_offset = local_assigns.fetch(:sidebar_offset, false)
  footer_classes = [
    "border-t border-imasus-dark-green/10 bg-gradient-to-b from-imasus-dark-green to-imasus-navy px-6 py-12 text-white/90 sm:px-10 lg:px-16",
    ("lg:ml-64" if sidebar_offset)
  ].compact.join(" ")
%>

<footer class="<%= footer_classes %>">
  <div class="space-y-10">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between">
      <%# EU funding notice %>
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:gap-6 lg:max-w-2xl">
        <%# self-start prevents the parent flex-col from stretching the
           near-square PNG to full container width on mobile. %>
        <%= image_tag "eu-funded-white.png", alt: "Funded by the European Union", class: "h-20 w-auto shrink-0 self-start" %>
        <p class="text-xs leading-relaxed text-white/60"><%= t("footer.eu_notice") %></p>
      </div>

      <%# Partners %>
      <div class="space-y-4 shrink-0">
        <p class="text-xs font-medium uppercase tracking-widest text-white/40"><%= t("footer.partners_label") %></p>
        <div class="grid grid-cols-2 items-center gap-x-10 gap-y-6">
          <%= image_tag "partners-inma.svg", alt: t("footer.partners.inma"), class: "h-12" %>
          <%= image_tag "partners-echn.svg", alt: t("footer.partners.echn"), class: "h-10" %>
          <%= image_tag "partners-lottozero.svg", alt: t("footer.partners.lottozero"), class: "h-6" %>
          <%= image_tag "partners-munkun.svg", alt: t("footer.partners.munkun"), class: "h-6" %>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-4 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex flex-col gap-3 text-xs text-white/40 sm:flex-row sm:items-center sm:gap-5">
        <p>
          <%= t("footer.copyright_prefix") %>
          <%= link_to t("footer.project_name"),
                "https://imasus.eu",
                target: "_blank",
                rel: "noopener noreferrer",
                class: "underline underline-offset-2 transition hover:text-white" %>.
        </p>
        <nav aria-label="<%= t("footer.legal_label") %>" class="flex gap-4">
          <%= link_to t("footer.privacy"), privacy_path, class: "underline underline-offset-2 transition hover:text-white" %>
          <%= link_to t("footer.terms"), terms_path, class: "underline underline-offset-2 transition hover:text-white" %>
        </nav>
      </div>
      <%= link_to "https://munkun.com",
            target: "_blank",
            rel: "noopener noreferrer",
            aria: { label: "#{t("footer.developed_by")} #{t("footer.partners.munkun")}" },
            class: "inline-flex items-center gap-3 self-start text-white/50 transition hover:text-white sm:self-auto" do %>
        <span class="text-xs font-medium uppercase tracking-widest"><%= t("footer.developed_by") %></span>
        <%= image_tag "munkun-light.svg", alt: t("footer.partners.munkun"), class: "h-4 w-auto opacity-80" %>
      <% end %>
    </div>
  </div>
</footer>
