<%# Bottom-of-sidebar auth chrome.
    Logged in: avatar (initials) + name + secondary line trigger; click
      reveals an upward flyout with email, Settings, Log out.
    Logged out: a single subdued "Log in" link, no flyout.

    The Stimulus controller (user_menu_controller.js) handles toggle,
    Escape, click-outside, and focus restore. %>

<% if logged_in? %>
  <%
    initials = current_user.name.to_s.split.map { |part| part[0] }.join.upcase[0, 2]
    secondary = current_user.institution.presence || t("roles.#{current_user.role}")
  %>
  <div data-user-menu data-controller="user-menu" class="relative border-t border-imasus-dark-green/10 p-3">
    <%# Flyout (initially hidden; positioned above the trigger) %>
    <div data-user-menu-target="flyout"
         hidden
         class="absolute bottom-full left-3 right-3 mb-2 rounded-2xl border border-imasus-dark-green/10 bg-white p-2 shadow-lg">
      <div class="border-b border-imasus-dark-green/10 px-3 py-2">
        <p data-user-menu-target="email"
           class="truncate text-xs text-imasus-dark-green/60">
          <%= current_user.email %>
        </p>
      </div>
      <%= link_to edit_settings_path,
                  class: "block rounded-xl px-3 py-2 text-sm font-medium text-imasus-dark-green hover:bg-imasus-mint/30" do %>
        <%= t("user_menu.settings") %>
      <% end %>
      <%= form_with url: session_path, method: :delete, local: true,
                    class: "block" do |f| %>
        <button type="submit"
                class="block w-full rounded-xl px-3 py-2 text-left text-sm font-medium text-imasus-red hover:bg-imasus-red/10">
          <%= t("user_menu.log_out") %>
        </button>
      <% end %>
    </div>

    <%# Trigger %>
    <button type="button"
            data-user-menu-target="trigger"
            data-action="user-menu#toggle"
            aria-haspopup="true"
            aria-expanded="false"
            class="flex w-full items-center gap-3 rounded-2xl px-2 py-2 text-left transition hover:bg-imasus-mint/20">
      <span data-user-menu-target="initials"
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-imasus-dark-green text-sm font-bold text-white">
        <%= initials %>
      </span>
      <span class="flex min-w-0 flex-1 flex-col">
        <span data-user-menu-target="display-name"
              class="truncate text-sm font-bold text-imasus-dark-green">
          <%= current_user.name %>
        </span>
        <span data-user-menu-target="secondary"
              class="truncate text-xs text-imasus-dark-green/60">
          <%= secondary %>
        </span>
      </span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-imasus-dark-green/50"
           fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"/>
      </svg>
    </button>
  </div>
<% else %>
  <div data-user-menu class="border-t border-imasus-dark-green/10 p-4">
    <%= link_to new_session_path,
                class: "inline-flex items-center gap-2 text-sm font-bold text-imasus-dark-green hover:underline" do %>
      <%= t("user_menu.log_in") %>
    <% end %>
  </div>
<% end %>
