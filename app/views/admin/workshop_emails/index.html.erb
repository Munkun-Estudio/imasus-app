<% content_for :title, t(".title", workshop: @workshop.title, default: "Emails for %{workshop}") %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <%= link_to workshop_path(@workshop),
              class: "inline-flex items-center text-sm font-semibold text-imasus-dark-green/70 hover:text-imasus-dark-green" do %>
    <%= t(".back_to_workshop", default: "← Back to workshop") %>
  <% end %>

  <header class="mt-6 flex flex-wrap items-end justify-between gap-4">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-imasus-dark-green/45"><%= t(".eyebrow", default: "Workshop Emails") %></p>
      <h1 class="mt-3 text-4xl font-bold text-imasus-dark-green"><%= t(".title", workshop: @workshop.title, default: "Emails for %{workshop}") %></h1>
      <p class="mt-4 text-base leading-7 text-stone-700"><%= t(".lead", default: "Manual workshop communications sent by admins. Use this history to confirm what went out and when.") %></p>
    </div>

    <%= link_to t(".compose", default: "Compose email"),
                new_admin_workshop_email_path(@workshop),
                class: form_primary_button_classes %>
  </header>

  <% if @broadcasts.any? %>
    <section class="mt-10 space-y-4">
      <% @broadcasts.each do |broadcast| %>
        <article class="rounded-3xl border border-imasus-dark-green/10 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45">
                <%= l(broadcast.sent_at, format: :long) %>
              </p>
              <h2 class="mt-2 text-xl font-bold text-imasus-dark-green"><%= broadcast.subject %></h2>
            </div>
            <span class="rounded-full bg-imasus-light-blue/35 px-3 py-1 text-xs font-semibold text-imasus-dark-green">
              <%= t(".recipient_count", count: broadcast.recipient_count, default: "%{count} recipients") %>
            </span>
          </div>

          <dl class="mt-4 grid gap-4 sm:grid-cols-3">
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".audience", default: "Audience") %></dt>
              <dd class="mt-1 text-sm text-stone-700"><%= broadcast.audience_label %></dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".sender", default: "Sender") %></dt>
              <dd class="mt-1 text-sm text-stone-700"><%= broadcast.sender.name %></dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".workshop", default: "Workshop") %></dt>
              <dd class="mt-1 text-sm text-stone-700"><%= @workshop.title %></dd>
            </div>
          </dl>

          <% if broadcast.pdf_attachment.attached? %>
            <div class="mt-5 rounded-2xl border border-imasus-dark-green/10 bg-imasus-light-blue/15 px-4 py-3 text-sm text-stone-700">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".attachment", default: "PDF attachment") %></p>
              <p class="mt-1">
                <%= link_to broadcast.pdf_attachment.filename.to_s,
                            url_for(broadcast.pdf_attachment),
                            class: "font-medium text-imasus-dark-green underline-offset-2 hover:underline" %>
              </p>
            </div>
          <% end %>

          <div class="mt-5 rounded-2xl bg-stone-50 p-4">
            <div class="prose prose-stone max-w-none trix-content">
              <%= sanitized_email_html(broadcast.body_html) %>
            </div>
          </div>
        </article>
      <% end %>
    </section>
  <% else %>
    <section class="mt-10 rounded-3xl border border-dashed border-imasus-dark-green/20 bg-white/60 p-8 text-center">
      <p class="text-lg font-semibold text-imasus-dark-green"><%= t(".empty_title", default: "No workshop emails sent yet.") %></p>
      <p class="mt-2 text-sm leading-7 text-stone-700"><%= t(".empty_body", default: "When an admin sends a workshop follow-up or news email, it will appear here.") %></p>
    </section>
  <% end %>
</div>
