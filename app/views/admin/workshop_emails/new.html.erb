<% content_for :title, t(".title", workshop: @workshop.title, default: "Compose email for %{workshop}") %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <%= link_to admin_workshop_emails_path(@workshop),
              class: "inline-flex items-center text-sm font-semibold text-imasus-dark-green/70 hover:text-imasus-dark-green" do %>
    <%= t(".back_to_history", default: "← Back to email history") %>
  <% end %>

  <header class="mt-6 max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-imasus-dark-green/45"><%= t(".eyebrow", default: "Workshop Emails") %></p>
    <h1 class="mt-3 text-4xl font-bold text-imasus-dark-green"><%= t(".title", workshop: @workshop.title, default: "Compose email for %{workshop}") %></h1>
    <p class="mt-4 text-base leading-7 text-stone-700"><%= t(".lead", default: "Write a manual follow-up or news update for this workshop. Preview it first, send a test to yourself if needed, then confirm the real send.") %></p>
  </header>

  <% if flash[:notice].present? %>
    <p class="mt-8 rounded-2xl bg-imasus-mint/40 px-4 py-3 text-sm text-imasus-dark-green">
      <%= flash[:notice] %>
    </p>
  <% end %>

  <% if flash[:alert].present? %>
    <p class="mt-8 rounded-2xl bg-imasus-red/10 px-4 py-3 text-sm text-imasus-red">
      <%= flash[:alert] %>
    </p>
  <% end %>

  <% if @draft.errors.any? %>
    <div class="<%= form_error_box_classes %> mt-8" role="alert">
      <h2 class="font-semibold text-imasus-red"><%= t(".errors_heading", count: @draft.errors.count, default: "Fix %{count} issue(s) before continuing.") %></h2>
      <ul class="mt-2 list-disc pl-5">
        <% @draft.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-8 grid gap-8 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <section>
      <% if @preview_mode %>
        <section class="mb-8 rounded-3xl border border-imasus-dark-green/10 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".preview_heading", default: "Preview") %></p>
              <h2 class="mt-2 text-2xl font-bold text-imasus-dark-green"><%= @draft.normalized_subject %></h2>
              <p class="mt-2 text-sm leading-6 text-stone-700"><%= t(".preview_explainer", default: "This step shows the final recipient count and the rendered email before you confirm the real send.") %></p>
            </div>
            <span class="rounded-full bg-imasus-mint/45 px-3 py-1 text-xs font-semibold text-imasus-dark-green">
              <%= t(".recipient_count", count: @draft.recipient_count, default: "%{count} recipients") %>
            </span>
          </div>

          <dl class="mt-5 grid gap-4 sm:grid-cols-2">
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".audience", default: "Recipients") %></dt>
              <dd class="mt-1 text-sm text-stone-700"><%= @draft.audience_label %></dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".workshop", default: "Workshop") %></dt>
              <dd class="mt-1 text-sm text-stone-700"><%= @workshop.title %></dd>
            </div>
          </dl>

          <% if @draft.pdf_attachment? %>
            <div class="mt-5 rounded-2xl border border-imasus-dark-green/10 bg-imasus-light-blue/15 px-4 py-3 text-sm text-stone-700">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".attachment", default: "PDF attachment") %></p>
              <p class="mt-1 font-medium text-imasus-dark-green"><%= @draft.pdf_attachment_filename %></p>
            </div>
          <% end %>

          <div class="mt-6 rounded-2xl border border-imasus-dark-green/10 bg-stone-50 p-5">
            <div class="prose prose-stone max-w-none trix-content">
              <%= @draft.normalized_html.html_safe %>
            </div>
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-3">
            <%= form_with url: admin_workshop_emails_path(@workshop),
                          local: true,
                          data: { turbo: false },
                          class: "contents" do %>
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <%= hidden_field_tag "workshop_email[audience]", @draft.audience %>
              <%= hidden_field_tag "workshop_email[subject]", @draft.subject %>
              <%= hidden_field_tag "workshop_email[body]", @draft.body %>
              <%= hidden_field_tag "workshop_email[pdf_attachment_signed_id]", @draft.pdf_attachment_signed_id if @draft.pdf_attachment? %>
              <%= hidden_field_tag :edit_mode, "1" %>
              <%= submit_tag t(".back_to_edit", default: "Back to edit"),
                             class: "inline-flex items-center justify-center rounded-full border border-imasus-dark-green/20 px-5 py-3 text-sm font-semibold text-imasus-dark-green transition hover:bg-imasus-dark-green/5" %>
            <% end %>

            <%= form_with url: admin_workshop_emails_path(@workshop),
                          local: true,
                          data: { turbo: false },
                          class: "contents" do %>
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <%= hidden_field_tag "workshop_email[audience]", @draft.audience %>
              <%= hidden_field_tag "workshop_email[subject]", @draft.subject %>
              <%= hidden_field_tag "workshop_email[body]", @draft.body %>
              <%= hidden_field_tag "workshop_email[pdf_attachment_signed_id]", @draft.pdf_attachment_signed_id if @draft.pdf_attachment? %>
              <%= hidden_field_tag :confirm_send, "1" %>
              <%= submit_tag t(".confirm_send", default: "Confirm and send"),
                             class: form_primary_button_classes,
                             data: { turbo_confirm: t(".confirm_prompt", default: "Send this email to the selected workshop recipients?") } %>
            <% end %>
          </div>
        </section>
      <% end %>

      <% unless @preview_mode %>
        <%= form_with url: admin_workshop_emails_path(@workshop),
                      scope: :workshop_email,
                      local: true,
                      data: { turbo: false },
                      class: "space-y-6" do |f| %>
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <div>
            <label class="<%= form_label_classes %>"><%= t(".workshop", default: "Workshop") %></label>
            <div class="<%= form_input_classes(readonly: true) %>"><%= @workshop.title %></div>
          </div>

          <div>
            <%= f.label :audience, t(".audience", default: "Recipients"), class: form_label_classes %>
            <%= f.select :audience,
                         WorkshopEmailBroadcast::AUDIENCES.map { |value| [t("admin.workshop_emails.audiences.#{value}", default: value.humanize), value] },
                         { include_blank: t(".select_audience", default: "Choose an audience"), selected: @draft.audience },
                         class: form_input_classes %>
          </div>

          <div>
            <%= f.label :subject, t(".subject", default: "Subject"), class: form_label_classes %>
            <%= f.text_field :subject, value: @draft.subject, required: true, autofocus: true, class: form_input_classes %>
          </div>

          <div>
            <%= f.label :body, t(".body", default: "Email body"), class: form_label_classes %>
            <p class="mb-2 text-xs text-imasus-dark-green/55"><%= t(".body_hint", default: "Use the editor for light formatting, links, and lists. The email will be sent as HTML with a plain-text fallback.") %></p>
            <%= rich_textarea_tag "workshop_email[body]", @draft.body, class: "trix-content trix-content--email-compose" %>
          </div>

          <div>
            <%= f.label :pdf_attachment, t(".attachment", default: "PDF attachment"), class: form_label_classes %>
            <p class="mb-2 text-xs text-imasus-dark-green/55"><%= t(".attachment_hint", default: "Optional. PDF only, up to 10 MB.") %></p>
            <%= render "shared/file_drop_zone",
                       form: f,
                       attribute: :pdf_attachment,
                       accept: "application/pdf,.pdf",
                       hint: t(".attachment_drop_zone_hint", default: "One PDF attachment. 10 MB max."),
                       label: t(".attachment_upload", default: "Upload a PDF") %>
            <%= hidden_field_tag "workshop_email[pdf_attachment_signed_id]", @draft.pdf_attachment_signed_id if @draft.pdf_attachment? %>

            <% if @draft.pdf_attachment? %>
              <div class="mt-3 rounded-2xl border border-imasus-dark-green/10 bg-stone-50 px-4 py-3">
                <p class="text-sm font-medium text-imasus-dark-green"><%= @draft.pdf_attachment_filename %></p>
                <p class="mt-1 text-xs text-stone-700"><%= number_to_human_size(@draft.pdf_attachment_byte_size) %></p>
                <label class="mt-3 inline-flex items-center gap-2 text-sm text-stone-700">
                  <%= check_box_tag "workshop_email[remove_pdf_attachment]", "1", false, class: "rounded border-imasus-dark-green/20 text-imasus-dark-green focus:ring-imasus-mint" %>
                  <span><%= t(".remove_attachment", default: "Remove this PDF") %></span>
                </label>
              </div>
            <% end %>
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <%= f.submit t(".preview", default: "Review recipients and preview"),
                         class: form_primary_button_classes %>
            <%= button_tag t(".send_test", default: "Send test to myself"),
                           type: :submit,
                           formaction: send_test_admin_workshop_emails_path(@workshop),
                           class: "inline-flex items-center justify-center rounded-full border border-imasus-dark-green/20 px-5 py-3 text-sm font-semibold text-imasus-dark-green transition hover:bg-imasus-dark-green/5" %>
          </div>
        <% end %>
      <% end %>

    </section>

    <aside class="space-y-5">
      <section class="rounded-3xl border border-imasus-dark-green/10 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-imasus-dark-green"><%= t(".sending_rules", default: "Sending rules") %></h2>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-stone-700">
          <li><%= t(".rules.workshop_only", default: "This message goes only to recipients associated with this workshop.") %></li>
          <li><%= t(".rules.test_first", default: "Use a test send before confirming the real broadcast.") %></li>
        </ul>
      </section>

      <% if @recent_broadcasts.present? %>
        <section class="rounded-3xl border border-imasus-dark-green/10 bg-white p-6 shadow-sm">
          <div class="flex items-center justify-between gap-3">
            <h2 class="text-lg font-bold text-imasus-dark-green"><%= t(".recent_history", default: "Recent sends") %></h2>
            <%= link_to t(".view_all", default: "View all"),
                        admin_workshop_emails_path(@workshop),
                        class: "text-sm font-semibold text-imasus-dark-green/70 hover:text-imasus-dark-green" %>
          </div>
          <div class="mt-4 space-y-4">
            <% @recent_broadcasts.each do |broadcast| %>
              <article class="rounded-2xl bg-stone-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= l(broadcast.sent_at, format: :long) %></p>
                <h3 class="mt-2 text-sm font-semibold text-imasus-dark-green"><%= broadcast.subject %></h3>
                <p class="mt-1 text-xs text-stone-700">
                  <%= t(".recent_meta",
                        default: "%{audience} · %{count} recipients",
                        audience: broadcast.audience_label,
                        count: broadcast.recipient_count) %>
                </p>
              </article>
            <% end %>
          </div>
        </section>
      <% end %>
    </aside>
  </div>
</div>
