<% content_for :title, t(".title", workshop: @workshop.title) %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <div class="max-w-5xl">
    <%= link_to workshop_path(@workshop),
                class: "inline-flex items-center text-sm text-imasus-dark-green/60 hover:text-imasus-dark-green" do %>
      <%= t(".back_to_workshop") %>
    <% end %>

    <h1 class="mt-2 text-3xl font-bold tracking-tight text-imasus-dark-green sm:text-4xl">
      <%= t(".heading", workshop: @workshop.title) %>
    </h1>
    <p class="mt-3 text-sm leading-relaxed text-imasus-dark-green/60">
      <%= t(".lead") %>
    </p>

    <% if flash[:notice].present? %>
      <p class="mt-6 rounded-2xl bg-imasus-mint/40 px-4 py-3 text-sm text-imasus-dark-green">
        <%= flash[:notice] %>
      </p>
    <% end %>
    <% if flash[:alert].present? %>
      <p class="mt-6 rounded-2xl bg-imasus-red/10 px-4 py-3 text-sm text-imasus-red">
        <%= flash[:alert] %>
      </p>
    <% end %>

    <% if @participations.empty? %>
      <p class="mt-8 rounded-2xl border border-dashed border-imasus-dark-green/15 bg-white px-6 py-10 text-sm leading-relaxed text-imasus-dark-green/60">
        <%= t(".empty") %>
      </p>
    <% else %>
      <ul class="mt-8 divide-y divide-imasus-dark-green/10 rounded-2xl border border-imasus-dark-green/10 bg-white">
        <% @participations.each do |participation| %>
          <% user = participation.user %>
          <% project_titles = @project_titles_by_user_id.fetch(user.id, []) %>
          <% removable = user.id != current_user.id && !user.admin? %>
          <li data-participant-row data-user-id="<%= user.id %>"
              class="flex flex-wrap items-center gap-4 px-5 py-4">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-imasus-dark-green text-sm font-bold text-white">
              <%= user.name.to_s.split.map { |part| part[0] }.join.upcase[0, 2] %>
            </span>
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-bold text-imasus-dark-green"><%= user.name %></p>
              <p class="truncate text-xs text-imasus-dark-green/60"><%= user.email %></p>
              <% if user.institution.present? || user.country.present? %>
                <p class="mt-1 text-xs text-imasus-dark-green/60">
                  <%= [ user.institution, user.country ].compact_blank.join(" · ") %>
                </p>
              <% end %>
              <% if project_titles.any? %>
                <p class="mt-1 text-xs text-imasus-dark-green/60">
                  <%= t(".projects", count: project_titles.size) %>:
                  <%= project_titles.join(" · ") %>
                </p>
              <% end %>
            </div>
            <div class="text-right text-xs text-imasus-dark-green/50">
              <%= t(".joined_on", date: l(participation.created_at.to_date)) %>
            </div>
            <% if removable %>
              <%= button_to workshop_participant_path(@workshop, user_id: user.id),
                            method: :delete,
                            data: { turbo_confirm: t(".confirm_remove", name: user.name) },
                            class: "inline-flex items-center rounded-full border border-imasus-red/30 px-3 py-1.5 text-xs font-bold text-imasus-red transition hover:bg-imasus-red/10" do %>
                <%= t(".remove") %>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>
