<p><%= t("password_reset_mailer.reset.greeting", default: "Hi %{name},", name: @user.name) %></p>

<p><%= t("password_reset_mailer.reset.body", default: "To reset your IMASUS password, open the following link within 2 hours:") %></p>

<p><%= link_to @url, @url %></p>

<p><%= t("password_reset_mailer.reset.ignore", default: "If you did not request a password reset, you can safely ignore this email.") %></p>
