<% content_for :title, t(".title") %>
<% content_for :meta_description, t(".meta_description") %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <header class="max-w-3xl">
    <h1 class="text-3xl font-bold text-imasus-dark-green"><%= t(".title") %></h1>
    <p class="mt-3 text-base text-imasus-dark-green/70"><%= t(".lead") %></p>
  </header>

  <div class="mt-10 space-y-12">
    <% @challenges_by_category.each do |category, challenges| %>
      <section data-category="<%= category %>">
        <h2 class="text-xl font-semibold text-imasus-dark-green">
          <%= t("challenges.categories.#{category}") %>
        </h2>
        <ul class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <% challenges.each do |challenge| %>
            <li>
              <%= render "card", challenge: challenge %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>
  </div>
</div>
