<%# locals: (challenge:) %>
<%
  pill_class = case challenge.category
               when "material" then "bg-imasus-dark-green/10 text-imasus-dark-green"
               when "design"   then "bg-imasus-navy/10 text-imasus-navy"
               when "system"   then "bg-imasus-light-blue/30 text-imasus-dark-green"
               when "business" then "bg-imasus-light-pink/40 text-imasus-dark-green"
               else                 "bg-imasus-dark-green/10 text-imasus-dark-green"
               end
%>
<%= turbo_frame_tag "preview" do %>
  <div data-controller="preview-sidebar"
       data-action="click->preview-sidebar#backdrop keydown.esc@window->preview-sidebar#close"
       class="fixed inset-0 z-40 flex items-end justify-end bg-imasus-dark-green/20 sm:items-stretch">
    <aside role="dialog"
           aria-modal="false"
           aria-labelledby="preview-heading-<%= challenge.code %>"
           tabindex="-1"
           data-preview-sidebar-target="dialog"
           class="flex h-[85vh] w-full flex-col overflow-y-auto rounded-t-2xl bg-white shadow-xl sm:h-screen sm:max-h-screen sm:w-full sm:max-w-md sm:rounded-none">
      <header class="flex items-start justify-between gap-4 border-b border-imasus-dark-green/10 px-6 py-4">
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2 text-xs">
            <span class="font-mono font-semibold text-imasus-dark-green">
              <%= challenge.code %>
            </span>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 font-medium <%= pill_class %>">
              <%= t("challenges.categories.#{challenge.category}") %>
            </span>
          </div>
          <h2 id="preview-heading-<%= challenge.code %>"
              class="mt-2 text-xl font-bold text-imasus-dark-green">
            <%= challenge.question %>
          </h2>
        </div>
        <button type="button"
                data-action="preview-sidebar#close"
                aria-label="<%= t("challenges.preview.close") %>"
                class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-imasus-dark-green/70 hover:bg-imasus-mint/20 hover:text-imasus-dark-green">
          <span aria-hidden="true">&times;</span>
        </button>
      </header>

      <div class="flex flex-col gap-4 px-6 py-5">
        <div class="prose prose-sm max-w-none text-imasus-dark-green/80">
          <%= simple_format challenge.description %>
        </div>

        <% if curator? %>
          <div class="mt-2">
            <%= link_to t("challenges.actions.edit"),
                  edit_challenge_path(challenge.to_param),
                  data: { role: "edit-challenge", turbo_frame: "_top" },
                  class: "inline-flex items-center rounded-md border border-imasus-dark-green/20 px-3 py-1.5 text-sm font-medium text-imasus-dark-green hover:bg-imasus-mint/20" %>
          </div>
        <% end %>
      </div>
    </aside>
  </div>
<% end %>
