<% content_for :title, t(".title", code: @challenge.code) %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <div class="max-w-3xl">
    <%= turbo_frame_tag dom_id(@challenge) do %>
      <h1 class="text-2xl font-bold text-imasus-dark-green">
        <%= t(".title", code: @challenge.code) %>
      </h1>

      <div class="mt-6">
        <%= render "form",
              challenge:  @challenge,
              form_url:   challenge_path(@challenge.to_param),
              cancel_url: challenges_path %>
      </div>
    <% end %>
  </div>
</div>
