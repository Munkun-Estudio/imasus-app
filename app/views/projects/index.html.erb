<% title = (current_user.admin? || current_user.facilitator?) ? t(".all_title") : t(".title") %>
<% content_for :title, title %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <header class="max-w-3xl">
    <h1 class="text-3xl font-bold text-imasus-dark-green"><%= title %></h1>
  </header>

  <% if @projects.empty? %>
    <div class="mt-12 max-w-md text-center">
      <p class="text-base font-semibold text-stone-700"><%= t(".empty_title") %></p>
      <p class="mt-2 text-sm text-stone-500"><%= t(".empty_body") %></p>
      <%= link_to t("nav.workshops"), workshops_path,
                  class: "mt-4 inline-block rounded-full bg-imasus-dark-green px-5 py-2.5 text-sm font-semibold text-white" %>
    </div>
  <% else %>
    <% projects_by_workshop = @projects.group_by(&:workshop) %>
    <div class="mt-10 space-y-10">
      <% projects_by_workshop.each do |workshop, projects| %>
        <section>
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/50"><%= workshop.title %></h2>
          <ul class="mt-4 divide-y divide-imasus-dark-green/10">
            <% projects.each do |project| %>
              <li class="py-4" data-project-id="<%= project.id %>">
                <%= link_to project_path(project),
                            class: "group flex items-start justify-between gap-4" do %>
                  <div>
                    <p class="font-semibold text-imasus-dark-green group-hover:underline"><%= project.title %></p>
                    <p class="mt-1 text-xs text-stone-500">
                      <%= t("projects.languages.#{project.language}") %> &middot;
                      <%= project.members.count %> <%= "member".pluralize(project.members.count) %>
                    </p>
                  </div>
                  <span class="rounded-full bg-stone-100 px-2.5 py-0.5 text-xs font-semibold text-stone-600"><%= project.status %></span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>
    </div>
  <% end %>
</div>
