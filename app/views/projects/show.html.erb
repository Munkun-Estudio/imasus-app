<% content_for :title, @project.title %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <%= link_to t("projects.show.back_to_index"), projects_path,
              class: "inline-flex items-center text-sm font-semibold text-imasus-dark-green/70 hover:text-imasus-dark-green" %>

  <% if current_user.facilitator? %>
    <div class="mt-4" data-role="facilitator-chip">
      <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-semibold text-stone-600">
        <%= t("projects.show.facilitator_chip") %>
      </span>
    </div>
  <% end %>

  <header class="mt-6 max-w-3xl">
    <div class="flex flex-wrap items-center gap-3">
      <span class="rounded-full bg-imasus-light-blue/30 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green">
        <%= t("projects.languages.#{@project.language}") %>
      </span>
    </div>
    <h1 class="mt-4 text-4xl font-bold text-imasus-dark-green"><%= @project.title %></h1>
    <% if @project.description.present? %>
      <div class="mt-5 text-lg leading-8 text-stone-700"><%= simple_format(@project.description) %></div>
    <% end %>
  </header>

  <% if @project.challenge.present? %>
    <section class="mt-10 max-w-3xl border-t border-imasus-dark-green/10 pt-8">
      <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/50"><%= t("projects.show.challenge_heading") %></h2>
      <div class="mt-4">
        <%= render "challenges/card", challenge: @project.challenge %>
      </div>
    </section>
  <% end %>

  <section class="mt-10 max-w-3xl border-t border-imasus-dark-green/10 pt-8">
    <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/50"><%= t("projects.show.members_heading") %></h2>
    <ul class="mt-4 space-y-2">
      <% @project.members.each do |member| %>
        <li class="flex items-center gap-3">
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-imasus-dark-green/10 text-xs font-bold text-imasus-dark-green">
            <%= member.name.split.map { |w| w[0] }.first(2).join %>
          </span>
          <span class="text-sm font-semibold text-stone-800" data-role="member-name"><%= member.name %></span>
          <% if @project.editable_by?(current_user) && member == current_user %>
            <%= button_to t("projects.show.leave"), project_membership_path(@project, @project.memberships.find_by(user: current_user)),
                          method: :delete,
                          class: "ml-auto text-xs text-stone-400 hover:text-red-600",
                          data: { turbo_confirm: "Are you sure?" } %>
          <% end %>
        </li>
      <% end %>
    </ul>

    <% if @project.editable_by?(current_user) %>
      <div class="mt-6">
        <% eligible = @project.workshop.participants.where.not(id: @project.member_ids) %>
        <% if eligible.any? %>
          <%= form_with model: ProjectMembership.new, url: project_memberships_path(@project), class: "flex items-end gap-3" do |f| %>
            <div class="flex-1">
              <%= f.label :user_id, t("project_memberships.form.user_select"),
                          class: "block text-xs font-semibold text-imasus-dark-green/60 mb-1" %>
              <%= f.select :user_id,
                           eligible.map { |u| [u.name, u.id] },
                           {},
                           class: "block w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm" %>
            </div>
            <%= f.submit t("project_memberships.form.submit"),
                         class: "rounded-full bg-imasus-dark-green px-5 py-2 text-sm font-semibold text-white" %>
          <% end %>
        <% else %>
          <div class="flex items-end gap-3 opacity-40">
            <div class="flex-1">
              <p class="text-xs font-semibold text-imasus-dark-green/60 mb-1"><%= t("project_memberships.form.user_select") %></p>
              <div class="block w-full rounded-md border border-imasus-dark-green/20 bg-stone-50 px-3 py-2 text-sm text-stone-400 cursor-not-allowed">
                <%= t("project_memberships.form.no_eligible") %>
              </div>
            </div>
            <div class="rounded-full bg-imasus-dark-green px-5 py-2 text-sm font-semibold text-white cursor-not-allowed">
              <%= t("project_memberships.form.submit") %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <section class="mt-10 max-w-3xl border-t border-imasus-dark-green/10 pt-8">
    <%= link_to t("projects.show.process_log"), project_log_entries_path(@project),
                class: "inline-flex items-center gap-2 rounded-xl border border-imasus-dark-green/20 px-5 py-4 text-sm font-semibold text-imasus-dark-green hover:bg-imasus-dark-green/5" %>
  </section>

  <% if @project.editable_by?(current_user) %>
    <footer class="mt-12 flex flex-wrap gap-4 border-t border-imasus-dark-green/10 pt-6 max-w-3xl">
      <%= link_to t("projects.show.edit"), edit_project_path(@project),
                  class: "rounded-full border border-imasus-dark-green/20 px-5 py-2.5 text-sm font-semibold text-imasus-dark-green" %>
      <%= button_to t("projects.show.delete"), @project,
                    method: :delete,
                    class: "rounded-full border border-red-200 px-5 py-2.5 text-sm font-semibold text-red-600",
                    data: { turbo_confirm: "Delete this project? This cannot be undone." } %>
    </footer>
  <% end %>
</div>
