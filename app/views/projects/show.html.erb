<% content_for :title, @project.title %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <%= link_to t("projects.show.back_to_index"), projects_path,
              class: "inline-flex items-center text-sm font-semibold text-imasus-dark-green/70 hover:text-imasus-dark-green" %>

  <% if current_user.facilitator? %>
    <div class="mt-4" data-role="facilitator-chip">
      <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-semibold text-stone-600">
        <%= t("projects.show.facilitator_chip") %>
      </span>
    </div>
  <% end %>

  <header class="mt-6 max-w-3xl">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <span class="rounded-full bg-imasus-light-blue/30 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green">
          <%= t("projects.languages.#{@project.language}") %>
        </span>
        <h1 class="mt-4 text-4xl font-bold text-imasus-dark-green"><%= @project.title %></h1>
        <% if @project.description.present? %>
          <div class="mt-3 text-base leading-7 text-stone-600"><%= simple_format(@project.description) %></div>
        <% end %>
      </div>

      <% if @project.editable_by?(current_user) %>
        <details class="relative mt-1 shrink-0">
          <summary class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-full border border-stone-200 text-stone-500 hover:bg-stone-50 hover:text-stone-700"
                   aria-label="<%= t("projects.show.more_options") %>">
            <span aria-hidden="true" class="text-sm font-bold leading-none tracking-widest">···</span>
          </summary>
          <div class="absolute right-0 top-full z-10 mt-2 w-44 rounded-xl border border-stone-100 bg-white py-1 shadow-lg">
            <%= link_to t("projects.show.edit"), edit_project_path(@project),
                        class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50" %>
            <%= button_to t("projects.show.delete"), @project,
                          method: :delete,
                          class: "block w-full cursor-pointer px-4 py-2 text-left text-sm text-red-500 hover:bg-red-50",
                          data: { turbo_confirm: t("projects.show.delete_confirm") } %>
          </div>
        </details>
      <% end %>
    </div>
  </header>

  <%# Avatar strip %>
  <section class="mt-8 max-w-3xl" aria-label="<%= t("projects.show.members_heading") %>">
    <div class="flex items-center gap-3">
      <div class="flex -space-x-2">
        <% @project.members.each do |member| %>
          <span title="<%= member.name %>"
                class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border-2 border-white bg-imasus-dark-green/10 text-xs font-bold uppercase text-imasus-dark-green">
            <%= member.name.split.map { |w| w[0].upcase }.first(2).join %>
          </span>
        <% end %>
      </div>
      <% if @project.editable_by?(current_user) %>
        <%= link_to t("projects.show.add_member"),
                    new_project_membership_path(@project),
                    data: { turbo_frame: "preview" },
                    class: "rounded-full border border-imasus-dark-green/30 px-4 py-1.5 text-xs font-semibold text-imasus-dark-green hover:bg-imasus-dark-green/5" %>
      <% end %>
    </div>
  </section>

  <%# 2-col card grid %>
  <div class="mt-8 grid max-w-3xl grid-cols-1 items-stretch gap-4 sm:grid-cols-2">
    <%# Process log card %>
    <%= link_to project_log_entries_path(@project),
                class: "group block rounded-2xl bg-imasus-dark-green text-white hover:bg-imasus-dark-green/90" do %>
      <div class="flex min-h-[11rem] flex-col justify-between px-7 py-7">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/60"><%= t("projects.show.process_log_eyebrow") %></p>
          <p class="mt-3 text-xl font-bold leading-snug"><%= t("projects.show.process_log_cta") %></p>
        </div>
        <span class="mt-8 block text-3xl font-light text-white/40 transition-colors group-hover:text-white/70" aria-hidden="true">→</span>
      </div>
    <% end %>

    <%# Publish card %>
    <% if @project.publishable_by?(current_user) %>
      <%= link_to new_project_publication_path(@project),
                  class: "group block rounded-2xl bg-imasus-mint text-imasus-dark-green hover:bg-imasus-mint/80" do %>
        <div class="flex min-h-[11rem] flex-col justify-between px-7 py-7">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/60"><%= t("projects.show.publish_eyebrow") %></p>
            <p class="mt-3 text-xl font-bold leading-snug"><%= t("projects.show.publish_cta") %></p>
          </div>
          <span class="mt-8 block text-3xl font-light text-imasus-dark-green/40 transition-colors group-hover:text-imasus-dark-green/70" aria-hidden="true">→</span>
        </div>
      <% end %>
    <% elsif @project.republishable_by?(current_user) %>
      <%= link_to published_project_path(slug: @project.slug),
                  class: "group block rounded-2xl border border-imasus-dark-green/20 bg-stone-50 hover:bg-stone-100" do %>
        <div class="flex min-h-[11rem] flex-col justify-between px-7 py-7">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/40"><%= t("projects.show.published_eyebrow") %></p>
            <p class="mt-3 text-xl font-bold leading-snug text-imasus-dark-green"><%= t("projects.show.view_publication_cta") %></p>
          </div>
          <span class="mt-8 block text-3xl font-light text-imasus-dark-green/30 transition-colors group-hover:text-imasus-dark-green/60" aria-hidden="true">→</span>
        </div>
      <% end %>
    <% end %>

    <%# Challenge card %>
    <% if @project.challenge.present? %>
      <%= render "challenges/card", challenge: @project.challenge %>
    <% else %>
      <div class="flex min-h-[10rem] flex-col rounded-2xl border border-dashed border-imasus-dark-green/20 bg-stone-50 p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/40"><%= t("projects.show.challenge_heading") %></p>
        <p class="mt-3 flex-1 text-sm text-stone-400"><%= t("projects.show.no_challenge") %></p>
        <% if @project.editable_by?(current_user) %>
          <%= link_to t("projects.show.edit"), edit_project_path(@project),
                      class: "mt-4 text-xs font-semibold text-imasus-dark-green/60 hover:text-imasus-dark-green" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
