<% errors_key = local_assigns.fetch(:submit_key, :submit_create) %>

<%= form_with(model: project, class: "space-y-6") do |f| %>
  <% if project.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <p class="text-sm font-semibold text-red-700">
        <%= t("projects.form.errors_heading", count: project.errors.count) %>
      </p>
      <ul class="mt-2 list-disc pl-5 text-sm text-red-600">
        <% project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :workshop_id %>

  <div>
    <%= f.label :title, t("projects.form.title"), class: "block text-sm font-semibold text-imasus-dark-green" %>
    <%= f.text_field :title,
                     class: "mt-1 block w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm shadow-sm focus:border-imasus-dark-green focus:outline-none",
                     required: true %>
  </div>

  <div>
    <%= f.label :description, t("projects.form.description"), class: "block text-sm font-semibold text-imasus-dark-green" %>
    <p class="text-xs text-stone-500 mt-0.5"><%= t("projects.form.description_hint") %></p>
    <%= f.text_area :description,
                    rows: 4,
                    class: "mt-1 block w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm shadow-sm focus:border-imasus-dark-green focus:outline-none" %>
  </div>

  <div>
    <%= f.label :challenge_id, t("projects.form.challenge"), class: "block text-sm font-semibold text-imasus-dark-green" %>
    <%= f.select :challenge_id,
                 Challenge.by_code.map { |c| ["#{c.code} — #{c.question}", c.id] },
                 { include_blank: t("projects.form.challenge_blank") },
                 class: "mt-1 block w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm shadow-sm focus:border-imasus-dark-green focus:outline-none" %>
  </div>

  <div>
    <%= f.label :language, t("projects.form.language"), class: "block text-sm font-semibold text-imasus-dark-green" %>
    <%= f.select :language,
                 Project::ALLOWED_LANGUAGES.map { |l| [t("projects.languages.#{l}"), l] },
                 {},
                 class: "mt-1 block w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm shadow-sm focus:border-imasus-dark-green focus:outline-none" %>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit t("projects.form.#{local_assigns.fetch(:submit_key, :submit_create)}"),
                 class: "rounded-full bg-imasus-dark-green px-6 py-2.5 text-sm font-semibold text-white" %>
    <%= link_to t("projects.form.cancel"), :back, class: "text-sm text-stone-500 hover:text-stone-700" %>
  </div>
<% end %>
