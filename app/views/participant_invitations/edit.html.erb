<% content_for :title, t("participant_invitations.edit.title", default: "Complete your IMASUS registration") %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <header class="max-w-3xl">
    <% if @workshop %>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-imasus-dark-green/50"><%= @workshop.title %></p>
    <% end %>
    <h1 class="mt-3 text-4xl font-bold text-imasus-dark-green"><%= t("participant_invitations.edit.title", default: "Complete your IMASUS registration") %></h1>
  </header>

  <% if @user.errors.any? %>
    <div role="alert" class="<%= form_error_box_classes %> mt-8 max-w-3xl">
      <ul class="space-y-1">
        <% @user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @user, url: participant_invitation_path(token: params[:token], locale: I18n.locale), method: :patch, local: true, class: "mt-8 max-w-3xl space-y-5" do |f| %>
    <div>
      <%= f.label :email, t("participant_invitations.edit.email", default: "Email"), class: form_label_classes %>
      <%= f.email_field :email, value: @user.email, readonly: true, class: form_input_classes(readonly: true) %>
    </div>
    <div>
      <%= f.label :password, t("participant_invitations.edit.password", default: "Password"), class: form_label_classes %>
      <%= f.password_field :password, required: true, autofocus: true, autocomplete: "new-password", class: form_input_classes %>
    </div>
    <div>
      <div class="border-t border-imasus-dark-green/10 pt-6">
        <h2 class="text-xl font-semibold text-imasus-dark-green"><%= t("participant_invitations.edit.profile_heading", default: "Profile") %></h2>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-stone-700"><%= t("participant_invitations.edit.profile_lead", default: "At the end of the workshop, the team will publish its work together with short participant profiles.") %></p>
      </div>
    </div>
    <div>
      <%= f.label :name, t("participant_invitations.edit.name", default: "Full name"), class: form_label_classes %>
      <%= f.text_field :name, required: true, class: form_input_classes %>
    </div>
    <div>
      <%= f.label :institution, t("participant_invitations.edit.institution", default: "Institution"), class: form_label_classes %>
      <%= f.text_field :institution, class: form_input_classes %>
    </div>
    <div>
      <%= f.label :country, t("participant_invitations.edit.country", default: "Country"), class: form_label_classes %>
      <%= f.select :country,
            options_for_select(participant_country_options, @user.country),
            { include_blank: true },
            class: form_input_classes %>
    </div>
    <div>
      <%= form_label_with_tooltip(
            t("participant_invitations.edit.bio", default: "Short bio"),
            t("participant_invitations.edit.bio_hint", default: "Tell us about your interests and experience.")
          ) %>
      <%= f.text_area :bio, rows: 4, class: form_textarea_classes %>
    </div>
    <div>
      <%= form_label_with_tooltip(
            t("participant_invitations.edit.links", default: "Links (one URL per line)"),
            t("participant_invitations.edit.links_hint", default: "Share your portfolio or social networks where you publish your work.")
          ) %>
      <%= f.text_area :links, rows: 4, class: form_textarea_classes %>
    </div>
    <%= f.submit t("participant_invitations.edit.submit", default: "Complete registration"), class: form_primary_button_classes %>
  <% end %>
</div>
