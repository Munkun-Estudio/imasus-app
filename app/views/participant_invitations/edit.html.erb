<h1><%= t("participant_invitations.edit.title", default: "Complete your IMASUS registration") %></h1>

<% if @user.errors.any? %>
  <ul role="alert">
    <% @user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
  </ul>
<% end %>

<%= form_with model: @user, url: participant_invitation_path(token: params[:token]), method: :patch, local: true do |f| %>
  <div>
    <%= f.label :email, t("participant_invitations.edit.email", default: "Email") %>
    <%= f.email_field :email, value: @user.email, readonly: true %>
  </div>
  <div>
    <%= f.label :name, t("participant_invitations.edit.name", default: "Full name") %>
    <%= f.text_field :name, required: true, autofocus: true %>
  </div>
  <div>
    <%= f.label :institution, t("participant_invitations.edit.institution", default: "Institution") %>
    <%= f.text_field :institution %>
  </div>
  <div>
    <%= f.label :country, t("participant_invitations.edit.country", default: "Country") %>
    <%= f.text_field :country %>
  </div>
  <div>
    <%= f.label :bio, t("participant_invitations.edit.bio", default: "Short bio") %>
    <%= f.text_area :bio, rows: 3 %>
  </div>
  <div>
    <%= f.label :links, t("participant_invitations.edit.links", default: "Links (one URL per line)") %>
    <%= f.text_area :links, rows: 3 %>
  </div>
  <div>
    <%= f.label :password, t("participant_invitations.edit.password", default: "Password") %>
    <%= f.password_field :password, required: true, autocomplete: "new-password" %>
  </div>
  <div>
    <%= f.label :password_confirmation, t("participant_invitations.edit.password_confirmation", default: "Confirm password") %>
    <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
  </div>
  <%= f.submit t("participant_invitations.edit.submit", default: "Complete registration") %>
<% end %>
