<% content_for :title, t(".title") %>
<% content_for :meta_description, t(".lead") %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <header class="max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-imasus-dark-green/50"><%= t(".eyebrow") %></p>
    <h1 class="mt-3 text-4xl font-bold text-imasus-dark-green"><%= t(".title") %></h1>
    <p class="mt-4 text-lg leading-8 text-stone-700"><%= t(".lead") %></p>
  </header>

  <% if @workshops.empty? %>
    <div class="mt-12 max-w-3xl rounded-xl border border-dashed border-imasus-dark-green/20 bg-white/70 px-6 py-8">
      <p class="text-lg font-semibold text-imasus-dark-green"><%= t(".empty_title") %></p>
      <p class="mt-2 text-stone-600"><%= t(".empty_body") %></p>
    </div>
  <% else %>
    <ul class="mt-10 max-w-5xl space-y-6">
      <% @workshops.each do |workshop| %>
        <li>
          <article class="rounded-xl border border-imasus-dark-green/10 bg-white px-6 py-6 shadow-sm">
            <div class="flex flex-wrap items-center gap-3">
              <span class="rounded-full bg-imasus-light-blue/35 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green">
                <%= workshop.partner %>
              </span>
              <% if attending_workshop?(workshop) %>
                <span class="rounded-full bg-imasus-mint/50 px-3 py-1 text-xs font-semibold text-imasus-dark-green">
                  <%= t(".attending") %>
                </span>
              <% end %>
            </div>

            <h2 class="mt-5 text-2xl font-bold text-imasus-dark-green">
              <%= link_to workshop.title, workshop_path(workshop), class: "hover:underline" %>
            </h2>

            <dl class="mt-4 space-y-2 text-sm text-stone-700">
              <div>
                <dt class="inline font-semibold text-imasus-dark-green"><%= t(".location") %>:</dt>
                <dd class="inline"><%= workshop.location %></dd>
              </div>
              <div>
                <dt class="inline font-semibold text-imasus-dark-green"><%= t(".dates") %>:</dt>
                <dd class="inline"><%= workshop_date_range(workshop) %></dd>
              </div>
            </dl>

            <p class="mt-5 max-w-3xl text-base leading-7 text-stone-700"><%= workshop_excerpt(workshop) %></p>

            <div class="mt-8 flex flex-wrap gap-3">
              <%= link_to t(".open_workshop"),
                          workshop_path(workshop),
                          class: "inline-flex items-center rounded-full bg-imasus-dark-green px-5 py-2.5 text-sm font-semibold text-white" %>
              <%= link_to t(".open_agenda"),
                          agenda_workshop_path(workshop),
                          class: "inline-flex items-center rounded-full border border-imasus-dark-green/20 px-5 py-2.5 text-sm font-semibold text-imasus-dark-green" %>
            </div>
          </article>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
