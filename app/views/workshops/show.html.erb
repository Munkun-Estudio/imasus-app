<% content_for :title, @workshop.title %>
<% content_for :meta_description, @workshop.description %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <%= link_to workshops_path,
              class: "inline-flex items-center text-sm font-semibold text-imasus-dark-green/70 hover:text-imasus-dark-green" do %>
    <%= t(".back_to_index") %>
  <% end %>

  <header class="mt-6 max-w-5xl">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-imasus-dark-green/50"><%= t(".eyebrow") %></p>
    <% if @attending %>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-imasus-mint/50 px-3 py-1 text-xs font-semibold text-imasus-dark-green">
          <%= t(".attending") %>
        </span>
      </div>
    <% end %>

    <%# Title + Edit-workshop CTA inline. Edit hides for non-managers. %>
    <div class="mt-5 flex flex-wrap items-start justify-between gap-4">
      <h1 class="flex-1 text-4xl font-bold text-imasus-dark-green"><%= @workshop.title %></h1>
      <% if @workshop.manageable_by?(current_user) %>
        <%= link_to t(".edit_workshop"),
                    edit_workshop_path(@workshop),
                    class: "shrink-0 inline-flex items-center rounded-full border border-imasus-dark-green/20 px-5 py-2.5 text-sm font-semibold text-imasus-dark-green hover:bg-imasus-dark-green/5" %>
      <% end %>
    </div>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-stone-700"><%= @workshop.description %></p>
  </header>

  <%# Metadata strip — Location / Dates / Agenda link / (managers) Participants count + Invite. %>
  <dl class="mt-10 flex max-w-5xl flex-wrap gap-x-12 gap-y-8 border-t border-imasus-dark-green/10 pt-8">
    <div class="min-w-[10rem]">
      <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".location") %></dt>
      <dd class="mt-2 text-base font-semibold text-imasus-dark-green"><%= @workshop.location %></dd>
    </div>
    <div class="min-w-[10rem]">
      <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".dates") %></dt>
      <dd class="mt-2 text-base font-semibold text-imasus-dark-green"><%= workshop_date_range(@workshop) %></dd>
    </div>
    <% if @workshop.manageable_by?(current_user) %>
      <div class="min-w-[12rem]">
        <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".participants") %></dt>
        <dd class="mt-2 flex flex-wrap items-center gap-3">
          <%= link_to t(".participant_count", count: @workshop.participants.count(&:participant?)),
                      workshop_participants_path(@workshop),
                      class: "text-base font-semibold text-imasus-dark-green hover:underline" %>
          <%= link_to t(".invite_participants"),
                      new_workshop_invitation_path(@workshop),
                      class: "inline-flex items-center rounded-full border border-imasus-dark-green/20 px-3 py-1 text-xs font-semibold text-imasus-dark-green hover:bg-imasus-dark-green/5" %>
        </dd>
      </div>
    <% elsif current_user&.facilitator? %>
      <%# Facilitator visiting a workshop they don't manage keeps the existing invite affordance. %>
      <div class="min-w-[12rem]">
        <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/45"><%= t(".participants") %></dt>
        <dd class="mt-2">
          <%= link_to t(".invite_participants"),
                      new_workshop_invitation_path(@workshop),
                      class: "inline-flex items-center rounded-full border border-imasus-dark-green/20 px-3 py-1 text-xs font-semibold text-imasus-dark-green hover:bg-imasus-dark-green/5" %>
        </dd>
      </div>
    <% end %>
    <% if current_user %>
      <div class="min-w-[10rem]">
        <%= link_to t(".agenda_page"),
                    agenda_workshop_path(@workshop),
                    class: "inline-flex items-center rounded-full border border-imasus-dark-green/20 px-5 py-2.5 text-sm font-semibold text-imasus-dark-green" %>
      </div>
    <% end %>
  </dl>

  <% if current_user %>
    <%= render "projects",
               workshop: @workshop,
               projects: @projects,
               attending: @attending,
               user_project_ids: @user_project_ids %>
  <% else %>
    <%= render "published_projects",
               workshop: @workshop,
               projects: @published_projects %>
  <% end %>
</div>
