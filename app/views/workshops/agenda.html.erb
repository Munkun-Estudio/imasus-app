<% content_for :title, t(".title", workshop: @workshop.title) %>
<% content_for :meta_description, @workshop.description %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <%= link_to workshop_path(@workshop),
              class: "inline-flex items-center text-sm font-semibold text-imasus-dark-green/70 hover:text-imasus-dark-green" do %>
    <%= t(".back_to_workshop") %>
  <% end %>

  <header class="mt-6 max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-imasus-dark-green/50"><%= t(".eyebrow") %></p>
    <h1 class="mt-3 text-4xl font-bold text-imasus-dark-green"><%= t(".title", workshop: @workshop.title) %></h1>
    <p class="mt-3 text-base font-semibold text-stone-700"><%= workshop_date_range(@workshop) %></p>
  </header>

  <div class="mt-10 max-w-5xl border-t border-imasus-dark-green/10 pt-8">
    <div class="prose prose-stone max-w-none prose-headings:text-imasus-dark-green prose-a:text-imasus-red">
      <%= workshop_agenda(@workshop) %>
    </div>
  </div>
</div>
