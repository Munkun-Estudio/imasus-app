<% content_for :title, t(".title", workshop: @workshop.title) %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <div class="max-w-3xl">
    <%= link_to workshop_path(@workshop),
                class: "inline-flex items-center text-sm text-imasus-dark-green/60 hover:text-imasus-dark-green" do %>
      <%= t(".back_to_workshop") %>
    <% end %>

    <h1 class="mt-2 text-3xl font-bold tracking-tight text-imasus-dark-green sm:text-4xl">
      <%= t(".heading") %>
    </h1>
    <p class="mt-3 text-sm leading-relaxed text-imasus-dark-green/60">
      <%= t(".lead") %>
    </p>

    <% if @workshop.errors.any? %>
      <div class="mt-6 rounded-2xl border border-imasus-red/30 bg-imasus-red/5 p-4" role="alert">
        <h2 class="text-sm font-semibold text-imasus-red">
          <%= t("workshops.edit.errors_heading", count: @workshop.errors.count) %>
        </h2>
        <ul class="mt-2 list-disc pl-5 text-sm text-imasus-red">
          <% @workshop.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%
      available = I18n.available_locales.map(&:to_s)
      current   = I18n.locale.to_s
      ordered   = ([ current ] + available).uniq
    %>

    <%= form_with model: @workshop, url: workshop_path(@workshop), method: :patch,
                  local: true, data: { controller: "locale-tabs" }, class: "mt-8 space-y-10" do |f| %>

      <%# Translated fields %>
      <section class="space-y-4">
        <h2 class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
          <%= t(".sections.translated") %>
        </h2>

        <div role="tablist" class="flex border-b border-imasus-dark-green/10"
             aria-label="<%= t("workshops.edit.locale_tabs_label", default: "Language") %>">
          <% ordered.each_with_index do |locale, i| %>
            <button type="button"
                    role="tab"
                    id="workshop-locale-tab-<%= locale %>"
                    aria-controls="workshop-locale-panel-<%= locale %>"
                    aria-selected="<%= i == 0 %>"
                    tabindex="<%= i == 0 ? 0 : -1 %>"
                    data-locale-tabs-target="tab"
                    data-locale="<%= locale %>"
                    data-action="click->locale-tabs#select keydown->locale-tabs#key"
                    class="px-4 py-2 text-sm font-medium border-b-2 -mb-px
                           <%= i == 0 ? 'border-imasus-dark-green text-imasus-dark-green' : 'border-transparent text-imasus-dark-green/50 hover:text-imasus-dark-green' %>">
              <%= locale.upcase %>
            </button>
          <% end %>
        </div>

        <% ordered.each_with_index do |locale, i| %>
          <div role="tabpanel"
               id="workshop-locale-panel-<%= locale %>"
               aria-labelledby="workshop-locale-tab-<%= locale %>"
               data-locale-tabs-target="panel"
               data-locale="<%= locale %>"
               <%= "hidden" unless i == 0 %>
               class="pt-6 space-y-4">
            <div>
              <label for="workshop_title_translations_<%= locale %>" class="<%= form_label_classes %>">
                <%= t(".fields.title") %> — <%= locale.upcase %>
              </label>
              <%= text_field_tag "workshop[title_translations][#{locale}]",
                    @workshop.title_translations[locale],
                    id: "workshop_title_translations_#{locale}",
                    class: form_input_classes %>
            </div>
            <div>
              <label for="workshop_description_translations_<%= locale %>" class="<%= form_label_classes %>">
                <%= t(".fields.description") %> — <%= locale.upcase %>
              </label>
              <%= text_area_tag "workshop[description_translations][#{locale}]",
                    @workshop.description_translations[locale],
                    id: "workshop_description_translations_#{locale}",
                    rows: 4,
                    class: form_textarea_classes %>
            </div>
          </div>
        <% end %>
      </section>

      <%# Plain fields %>
      <section class="space-y-4">
        <h2 class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
          <%= t(".sections.details") %>
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :location, t(".fields.location"), class: form_label_classes %>
            <%= f.text_field :location, class: form_input_classes %>
          </div>
          <div>
            <%= f.label :starts_on, t(".fields.starts_on"), class: form_label_classes %>
            <%= f.date_field :starts_on, class: form_input_classes %>
          </div>
          <div>
            <%= f.label :ends_on, t(".fields.ends_on"), class: form_label_classes %>
            <%= f.date_field :ends_on, class: form_input_classes %>
          </div>
        </div>
      </section>

      <%# Contact %>
      <section class="space-y-4">
        <h2 class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
          <%= t(".sections.contact") %>
        </h2>
        <div>
          <%= f.label :contact_email, t(".fields.contact_email"), class: form_label_classes %>
          <p class="mb-1 text-xs text-imasus-dark-green/55"><%= t(".fields.contact_email_hint") %></p>
          <%= f.email_field :contact_email, class: form_input_classes %>
        </div>
      </section>

      <%# TODO(workshop-agenda-edit): four-locale Trix agenda editor lands in its own spec. %>

      <div class="pt-2 flex flex-wrap items-center gap-3">
        <%= f.submit t(".submit"), class: form_primary_button_classes %>
        <%= link_to t(".cancel"), workshop_path(@workshop),
                    class: "text-sm text-imasus-dark-green/70 hover:text-imasus-dark-green" %>
      </div>
    <% end %>
  </div>
</div>
