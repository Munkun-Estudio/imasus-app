<% content_for :title, @project.title %>

<article class="bg-white">
  <% if @project.hero_image.attached? %>
    <div class="w-full bg-stone-100">
      <%= image_variant_tag @project.hero_image, preset: :hero,
                            alt: @project.title,
                            class: "mx-auto block max-h-[60vh] w-full object-cover" %>
    </div>
  <% end %>

  <div class="mx-auto max-w-3xl px-6 py-12 sm:px-10">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/50">
      <%= t("published_projects.show.workshop_label") %> · <%= @project.workshop.title %>
    </p>

    <h1 class="mt-4 text-4xl font-bold text-imasus-dark-green"><%= @project.title %></h1>

    <% if @project.challenge.present? %>
      <p class="mt-3">
        <span class="rounded-full bg-imasus-light-blue/35 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green">
          <%= @project.challenge.code %>
        </span>
      </p>
    <% end %>

    <% if @project.publication_updated_at %>
      <p class="mt-2 text-xs text-stone-400">
        <%= t("published_projects.show.last_updated", date: l(@project.publication_updated_at.to_date)) %>
      </p>
    <% end %>

    <div class="mt-10 prose prose-stone max-w-none">
      <%= @project.process_summary %>
    </div>

    <% if @project.members.any? %>
      <section class="mt-12 border-t border-stone-200 pt-8" aria-labelledby="published-project-team-heading">
        <h2 id="published-project-team-heading"
            class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
          <%= t("published_projects.show.members_heading") %>
        </h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <% @project.members.each do |member| %>
            <article data-team-member="<%= member.id %>"
                     class="rounded-2xl border border-imasus-dark-green/10 bg-stone-50 p-5">
              <div class="flex items-start gap-3">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-imasus-dark-green text-sm font-bold text-white">
                  <%= member.name.to_s.split.map { |part| part[0] }.join.upcase[0, 2] %>
                </span>
                <div class="min-w-0">
                  <h3 class="truncate text-sm font-bold text-imasus-dark-green"><%= member.name %></h3>
                  <% if member.institution.present? || member.country.present? %>
                    <p class="mt-1 text-xs text-imasus-dark-green/60">
                      <%= [ member.institution, member.country ].compact_blank.join(" · ") %>
                    </p>
                  <% end %>
                </div>
              </div>

              <% if member.bio.present? %>
                <p class="mt-4 text-sm leading-6 text-stone-700"><%= member.bio %></p>
              <% end %>

              <% links = participant_profile_links(member) %>
              <% if links.any? %>
                <ul class="mt-4 flex flex-wrap gap-2">
                  <% links.each do |url| %>
                    <li>
                      <%= link_to participant_profile_link_label(url), url,
                            target: "_blank",
                            rel: "noopener noreferrer",
                            class: "inline-flex items-center rounded-full border border-imasus-dark-green/15 bg-white px-3 py-1 text-xs font-semibold text-imasus-dark-green hover:bg-imasus-mint/20" %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if current_user && @project.republishable_by?(current_user) %>
      <div class="mt-10 border-t border-stone-200 pt-6">
        <%= link_to t("published_projects.show.edit_link"),
                    edit_project_publication_path(@project),
                    class: "text-sm font-semibold text-imasus-dark-green hover:underline" %>
      </div>
    <% end %>
  </div>
</article>
