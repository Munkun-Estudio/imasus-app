<%
  available = I18n.available_locales.map(&:to_s)
  current   = I18n.locale.to_s
  ordered   = ([ current ] + available).uniq
  selected_tag_ids = material.tags.pluck(:id)
%>

<%= form_with model: material, url: material_path(material), data: { controller: "locale-tabs" } do |f| %>
  <% if material.errors.any? %>
    <div class="mb-6 rounded-md border border-imasus-red/30 bg-imasus-red/5 p-4" role="alert">
      <h2 class="text-sm font-semibold text-imasus-red">
        <%= t("materials.form.errors_heading", count: material.errors.count) %>
      </h2>
      <ul class="mt-2 list-disc pl-5 text-sm text-imasus-red">
        <% material.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :trade_name, t("materials.form.trade_name_label"),
            class: "block text-sm font-medium text-imasus-dark-green" %>
      <%= f.text_field :trade_name,
            class: "mt-1 w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm focus:border-imasus-dark-green focus:outline-none focus:ring-1 focus:ring-imasus-dark-green" %>
    </div>

    <div>
      <%= f.label :availability_status, t("materials.form.availability_status_label"),
            class: "block text-sm font-medium text-imasus-dark-green" %>
      <%= f.select :availability_status,
            Material::AVAILABILITY_STATUSES.map { |status| [ t("materials.index.availability.#{status}"), status ] },
            {},
            class: "mt-1 w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm focus:border-imasus-dark-green focus:outline-none focus:ring-1 focus:ring-imasus-dark-green" %>
    </div>

    <div>
      <%= f.label :supplier_name, t("materials.form.supplier_name_label"),
            class: "block text-sm font-medium text-imasus-dark-green" %>
      <%= f.text_field :supplier_name,
            class: "mt-1 w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm focus:border-imasus-dark-green focus:outline-none focus:ring-1 focus:ring-imasus-dark-green" %>
    </div>

    <div>
      <%= f.label :supplier_url, t("materials.form.supplier_url_label"),
            class: "block text-sm font-medium text-imasus-dark-green" %>
      <%= f.url_field :supplier_url,
            class: "mt-1 w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm focus:border-imasus-dark-green focus:outline-none focus:ring-1 focus:ring-imasus-dark-green" %>
    </div>

    <div class="sm:col-span-2">
      <%= f.label :material_of_origin, t("materials.form.material_of_origin_label"),
            class: "block text-sm font-medium text-imasus-dark-green" %>
      <%= f.text_field :material_of_origin,
            class: "mt-1 w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm focus:border-imasus-dark-green focus:outline-none focus:ring-1 focus:ring-imasus-dark-green" %>
    </div>
  </div>

  <div class="mt-8">
    <div role="tablist"
         aria-label="<%= t("materials.form.locale_tabs_label") %>"
         class="flex flex-wrap gap-1 border-b border-imasus-dark-green/10">
      <% ordered.each_with_index do |locale, i| %>
        <button type="button"
                role="tab"
                id="material-locale-tab-<%= locale %>"
                aria-controls="material-locale-panel-<%= locale %>"
                aria-selected="<%= i == 0 %>"
                tabindex="<%= i == 0 ? 0 : -1 %>"
                data-locale-tabs-target="tab"
                data-locale="<%= locale %>"
                data-action="click->locale-tabs#select keydown->locale-tabs#key"
                class="px-4 py-2 text-sm font-medium border-b-2 -mb-px
                       <%= i == 0 ? 'border-imasus-dark-green text-imasus-dark-green' : 'border-transparent text-imasus-dark-green/50 hover:text-imasus-dark-green' %>">
          <%= locale.upcase %>
        </button>
      <% end %>
    </div>

    <% ordered.each_with_index do |locale, i| %>
      <div role="tabpanel"
           id="material-locale-panel-<%= locale %>"
           aria-labelledby="material-locale-tab-<%= locale %>"
           data-locale-tabs-target="panel"
           data-locale="<%= locale %>"
           <%= "hidden" unless i == 0 %>
           class="pt-6 space-y-4">
        <% Material::TRANSLATED_ATTRIBUTES.each do |attribute| %>
          <div>
            <label for="material_<%= attribute %>_translations_<%= locale %>"
                   class="block text-sm font-medium text-imasus-dark-green">
              <%= t("materials.show.sections.#{attribute}") %> — <%= locale.upcase %>
            </label>
            <%= text_area_tag "material[#{attribute}_translations][#{locale}]",
                  material.public_send(:"#{attribute}_in", locale),
                  id: "material_#{attribute}_translations_#{locale}",
                  rows: attribute == :description ? 6 : 4,
                  class: "mt-1 w-full rounded-md border border-imasus-dark-green/20 px-3 py-2 text-sm focus:border-imasus-dark-green focus:outline-none focus:ring-1 focus:ring-imasus-dark-green" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <fieldset class="mt-8">
    <legend class="text-sm font-semibold text-imasus-dark-green">
      <%= t("materials.form.tags_label") %>
    </legend>
    <%= hidden_field_tag "material[tag_ids][]", "" %>
    <div class="mt-3 grid gap-5 sm:grid-cols-3">
      <% Tag::FACETS.each do |facet| %>
        <% tags = (tags_by_facet[facet] || []).sort_by { |tag| tag.name_in(Tag::BASE_LOCALE).to_s.downcase } %>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-imasus-dark-green/60">
            <%= t("materials.index.facets.#{facet}.title") %>
          </p>
          <div class="mt-2 space-y-2">
            <% tags.each do |tag| %>
              <label class="flex items-start gap-2 text-sm text-imasus-dark-green">
                <%= check_box_tag "material[tag_ids][]",
                      tag.id,
                      selected_tag_ids.include?(tag.id),
                      id: "material_tag_ids_#{tag.id}",
                      class: "mt-0.5 rounded border-imasus-dark-green/25 text-imasus-dark-green focus:ring-imasus-mint" %>
                <span><%= tag.name_in(I18n.locale) || tag.name_in(Tag::BASE_LOCALE) %></span>
              </label>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </fieldset>

  <div class="mt-8 flex items-center gap-3">
    <%= f.submit t("materials.form.submit_update"),
          class: "rounded-md bg-imasus-dark-green px-4 py-2 text-sm font-semibold text-white hover:bg-imasus-dark-green/90" %>
    <%= link_to t("materials.form.cancel"),
          material_path(material),
          class: "text-sm text-imasus-dark-green/70 hover:text-imasus-dark-green" %>
  </div>
<% end %>
