<%# locals: (material:) %>
<article data-material="<%= material.slug %>"
         data-controller="card-media"
         class="group flex h-full flex-col overflow-hidden rounded-lg border border-imasus-dark-green/10 bg-white shadow-sm transition hover:shadow-md">
  <div class="relative aspect-[4/3] overflow-hidden bg-imasus-mint/20">
    <% if material.macro_asset&.file&.attached? %>
      <%= image_variant_tag material.macro_asset.file,
            preset: :card,
            alt: material.trade_name,
            class: "h-full w-full object-cover" %>
    <% end %>
  </div>

  <div class="flex flex-1 flex-col gap-3 p-4">
    <h3 class="text-base font-semibold text-imasus-dark-green">
      <%= material.trade_name %>
    </h3>

    <% if material.supplier_name.present? %>
      <p class="text-sm text-imasus-dark-green/70">
        <% if material.supplier_url.present? %>
          <%= link_to material.supplier_name, material.supplier_url,
                target: "_blank", rel: "noopener",
                class: "hover:underline" %>
        <% else %>
          <%= material.supplier_name %>
        <% end %>
      </p>
    <% end %>

    <div class="mt-auto flex flex-wrap items-center gap-2 text-xs">
      <span data-role="availability"
            class="inline-flex items-center rounded-full bg-imasus-mint/30 px-2.5 py-0.5 font-medium text-imasus-dark-green">
        <%= t("materials.index.availability.#{material.availability_status}") %>
      </span>
      <% if material.material_of_origin.present? %>
        <span class="text-imasus-dark-green/60">
          <%= material.material_of_origin %>
        </span>
      <% end %>
    </div>
  </div>
</article>
