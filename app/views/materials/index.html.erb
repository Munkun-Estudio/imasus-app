<% content_for :title, t(".title") %>

<div class="px-6 py-12 sm:px-10 lg:px-16">
  <header class="max-w-3xl">
    <h1 class="text-3xl font-bold text-imasus-dark-green"><%= t(".title") %></h1>
    <p class="mt-3 text-base text-imasus-dark-green/70"><%= t(".lead") %></p>
  </header>

  <%= form_with url: materials_path, method: :get, local: true,
        class: "mt-8 max-w-xl",
        data: { turbo: "false" } do |form| %>
    <% @selected_slugs_by_facet.each do |facet, slugs| %>
      <%= form.hidden_field facet, value: slugs.join(",") %>
    <% end %>
    <div class="relative">
      <%= form.label :q, t(".search_label"), class: "sr-only" %>
      <%= form.search_field :q,
            value: @query,
            placeholder: t(".search_placeholder"),
            autocomplete: "off",
            class: "w-full rounded-md border border-imasus-dark-green/20 bg-white px-4 py-2 pr-10 text-sm text-imasus-dark-green placeholder:text-imasus-dark-green/40 focus:border-imasus-dark-green focus:outline-none" %>
    </div>
  <% end %>

  <div class="mt-8 flex flex-wrap items-center gap-3">
    <% if @any_filters_active %>
      <%= link_to t(".clear_all"),
            materials_path,
            data: { role: "clear-all" },
            class: "inline-flex items-center rounded-full border border-imasus-dark-green/20 bg-white px-4 py-1.5 text-sm font-medium text-imasus-dark-green hover:bg-imasus-mint/20" %>
    <% end %>
  </div>

  <section class="mt-6 space-y-6" aria-label="<%= t(".facets_label") %>">
    <% Tag::FACETS.each do |facet| %>
      <% tags = (@tags_by_facet[facet] || []).sort_by { |t| t.name_in(Tag::BASE_LOCALE).to_s.downcase } %>
      <% next if tags.empty? %>
      <div data-facet="<%= facet %>">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-imasus-dark-green/60">
          <%= t(".facets.#{facet}.title") %>
        </h2>
        <ul class="mt-2 flex flex-wrap gap-2">
          <% tags.each do |tag| %>
            <% active = materials_chip_active?(facet, tag.slug, selected_by_facet: @selected_slugs_by_facet) %>
            <% count  = @chip_counts[tag.id] || 0 %>
            <li>
              <%= link_to materials_chip_toggle_url(facet, tag.slug, selected_by_facet: @selected_slugs_by_facet, query: @query),
                    data: { "chip-slug" => tag.slug },
                    class: "inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-medium #{active ? "bg-imasus-dark-green text-white" : "bg-white text-imasus-dark-green border border-imasus-dark-green/20 hover:bg-imasus-mint/20"}" do %>
                <span><%= tag.name_in(I18n.locale) || tag.name_in(Tag::BASE_LOCALE) %></span>
                <span data-role="chip-count" class="text-xs <%= active ? "text-white/80" : "text-imasus-dark-green/60" %>"><%= count %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </section>

  <% if @materials.empty? %>
    <p data-role="empty-state" class="mt-12 text-imasus-dark-green/60">
      <%= t(".empty_state") %>
    </p>
  <% else %>
    <ul class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% @materials.each do |material| %>
        <li>
          <%= render "card", material: material %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
