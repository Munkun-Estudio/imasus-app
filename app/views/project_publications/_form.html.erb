<% form_url    = local_assigns.fetch(:form_url) %>
<% form_method = local_assigns.fetch(:form_method, :post) %>
<% form_scope  = form_method == :post ? "new" : "edit" %>

<%= form_with model: project,
              url: form_url,
              method: form_method,
              multipart: true,
              class: "space-y-8" do |f| %>
  <% if project.errors.any? %>
    <div class="<%= form_error_box_classes %>">
      <ul class="list-disc pl-5">
        <% project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="rounded-2xl border border-imasus-dark-green/10 bg-white p-6">
    <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/50">
      <%= t("project_publications.new.challenge_heading") %>
    </h2>
    <p class="mt-2 text-base text-imasus-dark-green">
      <% if project.challenge.present? %>
        <%= "#{project.challenge.code} — #{project.challenge.question}" %>
      <% else %>
        <%= t("project_publications.new.no_challenge") %>
      <% end %>
    </p>
  </section>

  <section class="rounded-2xl border border-imasus-dark-green/10 bg-white p-6">
    <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/50">
      <%= t("project_publications.new.composition_heading") %>
    </h2>
    <p class="mt-2 text-sm text-stone-500"><%= t("project_publications.new.composition_hint") %></p>

    <div class="mt-4">
      <%= f.label :process_summary, t("project_publications.new.process_summary_label"),
                  class: "block text-sm font-semibold text-imasus-dark-green" %>
      <%= f.rich_text_area :process_summary,
                           class: "mt-1 block w-full rounded-md border border-imasus-dark-green/20" %>
    </div>
  </section>

  <section class="rounded-2xl border border-imasus-dark-green/10 bg-white p-6">
    <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/50">
      <%= t("project_publications.new.hero_image_label") %>
    </h2>
    <%# TODO: add croppable crop UI once gem compatibility with mini_magick is confirmed %>
    <p class="mt-1 text-xs text-stone-500"><%= t("project_publications.new.hero_image_hint") %></p>
    <% if project.hero_image.attached? && project.hero_image.blob&.persisted? %>
      <div class="mt-3">
        <%= image_variant_tag project.hero_image, preset: :card,
                              alt: project.title, class: "rounded-lg" %>
      </div>
    <% end %>
    <%= f.file_field :hero_image, accept: "image/png,image/jpeg",
                     class: "mt-3 block text-sm" %>
  </section>

  <div class="flex items-center gap-4">
    <%= f.submit t("project_publications.#{form_scope}.submit"),
                 class: "rounded-full bg-imasus-dark-green px-6 py-2.5 text-sm font-semibold text-white" %>
    <%= link_to t("project_publications.#{form_scope}.cancel"),
                project_path(project),
                class: "text-sm text-stone-500 hover:text-stone-700" %>
  </div>
<% end %>
