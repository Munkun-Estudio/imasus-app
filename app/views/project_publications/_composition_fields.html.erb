<% show_back = local_assigns.fetch(:show_back, false) %>

<div class="rounded-2xl border border-imasus-dark-green/10 bg-white p-8">
  <% if show_back %>
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-imasus-dark-green/40">
      <%= t("project_publications.new.step_label", current: 6, total: 6) %>
    </p>
  <% end %>
  <h2 class="<%= show_back ? "mt-2" : "" %> text-xl font-bold text-imasus-dark-green">
    <%= t("project_publications.new.composition_heading") %>
  </h2>
  <p class="mt-2 text-sm text-stone-500"><%= t("project_publications.new.composition_hint") %></p>

  <%# Hero image %>
  <div class="mt-6">
    <p class="text-sm font-semibold text-imasus-dark-green">
      <%= t("project_publications.new.hero_image_label") %>
    </p>
    <p class="mt-0.5 text-xs text-stone-500"><%= t("project_publications.new.hero_image_hint") %></p>
    <%# TODO: add croppable crop UI once gem compatibility with mini_magick is confirmed %>
    <% if project.hero_image.attached? && project.hero_image.blob&.persisted? %>
      <div class="mt-3">
        <%= image_variant_tag project.hero_image, preset: :card,
                              alt: project.title, class: "rounded-lg" %>
      </div>
    <% end %>
    <%= f.file_field :hero_image, accept: "image/png,image/jpeg",
                     class: "mt-3 block text-sm" %>
  </div>

  <%# Process summary (Trix) %>
  <div class="mt-6">
    <%= f.label :process_summary, t("project_publications.new.process_summary_label"),
                class: "block text-sm font-semibold text-imasus-dark-green" %>
    <%= f.rich_text_area :process_summary,
                         class: "mt-1 block w-full rounded-md border border-imasus-dark-green/20" %>
  </div>
</div>

<div class="mt-6 flex items-center <%= show_back ? "justify-between" : "justify-end" %>">
  <% if show_back %>
    <button type="button" data-action="click->publication-wizard#back"
            class="text-sm font-semibold text-stone-500 hover:text-stone-700">
      <%= t("project_publications.new.back") %>
    </button>
  <% end %>
  <div class="flex items-center gap-4">
    <%= f.submit t("project_publications.#{form_scope}.submit"),
                 class: "rounded-full bg-imasus-dark-green px-6 py-2.5 text-sm font-semibold text-white hover:bg-imasus-dark-green/90" %>
    <%= link_to t("project_publications.#{form_scope}.cancel"),
                project_path(project),
                class: "text-sm text-stone-500 hover:text-stone-700" %>
  </div>
</div>
