<div class="<%= form_page_classes %>">
  <div class="<%= form_card_classes %>">
    <h1 class="text-3xl font-bold text-imasus-dark-green"><%= t("password_resets.edit.title", default: "Choose a new password") %></h1>

    <% if @user.errors.any? %>
      <div role="alert" class="<%= form_error_box_classes %> mt-6">
        <ul class="space-y-1">
          <% @user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with url: password_reset_path(token: params[:token]), method: :patch, local: true, class: "mt-8 space-y-5" do |f| %>
      <div>
        <%= f.label :password, t("password_resets.edit.password", default: "New password"), class: form_label_classes %>
        <%= f.password_field :password, required: true, autocomplete: "new-password", class: form_input_classes %>
      </div>
      <div>
        <%= f.label :password_confirmation, t("password_resets.edit.password_confirmation", default: "Confirm password"), class: form_label_classes %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password", class: form_input_classes %>
      </div>
      <%= f.submit t("password_resets.edit.submit", default: "Update password"), class: form_primary_button_classes %>
    <% end %>
  </div>
</div>
