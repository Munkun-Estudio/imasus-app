<div class="<%= form_page_classes %>">
  <div class="<%= form_card_classes %>">
    <h1 class="text-3xl font-bold text-imasus-dark-green"><%= t("password_resets.new.title", default: "Reset your password") %></h1>
    <p class="mt-3 text-base leading-7 text-stone-700"><%= t("password_resets.new.lead", default: "Enter your email and we will send you a one-time link to choose a new password.") %></p>

    <%= form_with url: password_resets_path, local: true, class: "mt-8 space-y-5" do |f| %>
      <div>
        <%= f.label :email, t("password_resets.new.email", default: "Email"), class: form_label_classes %>
        <%= f.email_field :email, required: true, autofocus: true, class: form_input_classes %>
      </div>
      <%= f.submit t("password_resets.new.submit", default: "Send reset link"), class: form_primary_button_classes %>
    <% end %>
  </div>
</div>
