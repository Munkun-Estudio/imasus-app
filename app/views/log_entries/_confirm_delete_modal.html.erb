<%= turbo_frame_tag "modal" do %>
  <div data-controller="modal"
       data-action="keydown.esc@window->modal#close click->modal#backdrop"
       class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
    <div role="dialog"
         aria-modal="true"
         aria-labelledby="confirm-delete-entry-title"
         tabindex="-1"
         data-modal-target="dialog"
         class="w-full max-w-md rounded-xl bg-white p-6 shadow-xl">
      <h2 id="confirm-delete-entry-title" class="text-lg font-semibold text-imasus-dark-green">
        <%= t("log_entries.confirm_delete.title") %>
      </h2>
      <p class="mt-2 text-sm text-imasus-dark-green/80">
        <%= t("log_entries.confirm_delete.body") %>
      </p>

      <div class="mt-6 flex items-center justify-end gap-2">
        <button type="button"
                data-action="modal#close"
                class="rounded-md border border-imasus-dark-green/20 px-4 py-2 text-sm font-medium text-imasus-dark-green hover:bg-stone-50">
          <%= t("log_entries.confirm_delete.cancel") %>
        </button>

        <%= button_to t("log_entries.confirm_delete.confirm"),
              project_log_entry_path(project, log_entry),
              method: :delete,
              data: { role: "confirm-delete-log-entry", turbo_frame: "_top" },
              class: "rounded-md bg-imasus-red px-4 py-2 text-sm font-semibold text-white hover:bg-imasus-red/90" %>
      </div>
    </div>
  </div>
<% end %>
