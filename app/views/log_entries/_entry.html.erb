<article class="rounded-xl border border-imasus-dark-green/10 bg-white p-6"
         data-role="log-entry"
         data-entry-id="<%= entry.id %>">
  <header class="flex items-center gap-3">
    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-imasus-dark-green/10 text-xs font-bold text-imasus-dark-green">
      <%= entry.author.name.split.map { |w| w[0] }.first(2).join %>
    </span>
    <div>
      <span class="text-sm font-semibold text-stone-800" data-role="author-name"><%= entry.author.name %></span>
      <time class="block text-xs text-stone-400" datetime="<%= entry.created_at.iso8601 %>">
        <%= t("log_entries.entry.time_ago", time: time_ago_in_words(entry.created_at)) %>
      </time>
    </div>

    <% if entry.author == current_user || current_user&.admin? %>
      <div class="ml-auto">
        <%= link_to t("log_entries.entry.delete"),
                    delete_confirmation_project_log_entry_path(@project, entry),
                    class: "text-xs text-stone-400 hover:text-red-600",
                    data: { turbo_frame: "modal", role: "delete-log-entry" } %>
      </div>
    <% end %>
  </header>

  <div class="mt-4 prose prose-stone prose-sm max-w-none">
    <%= entry.body %>
  </div>

  <% if entry.media.attached? %>
    <div class="mt-4 flex flex-wrap gap-3">
      <% entry.media.each do |attachment| %>
        <% if attachment.video? %>
          <div data-controller="deferred-video"
               data-deferred-video-url-value="<%= media_project_log_entry_path(@project, entry, attachment_id: attachment.id) %>">
            <button type="button"
                    data-role="log-entry-video"
                    data-media-url="<%= media_project_log_entry_path(@project, entry, attachment_id: attachment.id) %>"
                    data-action="deferred-video#load"
                    class="flex h-36 w-48 items-center justify-center rounded-lg bg-imasus-dark-green text-white">
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-white/15 ring-1 ring-white/35">
                <%= heroicon :play, class: "h-5 w-5 translate-x-0.5" %>
              </span>
              <span class="sr-only"><%= t("log_entries.entry.play_video") %></span>
            </button>
          </div>
        <% else %>
          <%= image_variant_tag attachment,
                preset: :log_entry_thumbnail,
                alt: attachment.filename.to_s,
                data: { role: "log-entry-image" },
                class: "max-h-48 rounded-lg object-cover" %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</article>
