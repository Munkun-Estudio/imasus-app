<%= form_with model: [@project, log_entry], class: "space-y-6" do |f| %>
  <% if log_entry.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <h2 class="text-sm font-semibold text-red-700">
        <%= t("log_entries.form.errors_heading", count: log_entry.errors.count) %>
      </h2>
      <ul class="mt-2 list-disc pl-5 text-sm text-red-600">
        <% log_entry.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :body, t("log_entries.form.body"),
                class: "block text-sm font-semibold text-imasus-dark-green mb-2" %>
    <%= f.rich_text_area :body,
                         class: "block w-full rounded-md border border-imasus-dark-green/20 min-h-[8rem]" %>
  </div>

  <div>
    <%= f.label :media, t("log_entries.form.media"),
                class: "block text-sm font-semibold text-imasus-dark-green mb-2" %>
    <%= render "shared/file_drop_zone",
               form: f,
               attribute: :media,
               multiple: true,
               accept: "image/jpeg,image/png,image/webp,video/mp4,video/quicktime",
               hint: t("log_entries.form.media_hint") %>
  </div>

  <div class="flex gap-4">
    <%= f.submit t("log_entries.form.submit"),
                 class: "rounded-full bg-imasus-dark-green px-6 py-2.5 text-sm font-semibold text-white" %>
    <%= link_to t("log_entries.form.cancel"), project_log_entries_path(@project),
                class: "rounded-full border border-imasus-dark-green/20 px-6 py-2.5 text-sm font-semibold text-imasus-dark-green" %>
  </div>
<% end %>
