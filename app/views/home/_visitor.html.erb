<div data-home-variant="visitor" class="px-6 py-12 sm:px-10 lg:px-16 lg:py-16">
  <%# Hero band %>
  <section class="max-w-3xl">
    <p class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
      <%= t(".hero.eyebrow") %>
    </p>

    <h1 class="mt-4 text-4xl font-bold leading-[1.1] tracking-tight text-imasus-dark-green sm:text-5xl lg:text-6xl">
      <%= t(".hero.heading") %>
    </h1>

    <p class="mt-8 max-w-xl text-base leading-relaxed text-imasus-dark-green/60">
      <%= t(".hero.lead") %>
    </p>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href="#workshops"
         class="inline-flex items-center rounded-full bg-imasus-dark-green px-5 py-2.5 text-sm font-bold text-white transition hover:bg-imasus-navy">
        <%= t(".hero.see_workshops") %>
      </a>
      <a href="<%= new_session_path %>"
         class="inline-flex items-center rounded-full border border-imasus-dark-green/15 px-5 py-2.5 text-sm font-bold text-imasus-dark-green transition hover:border-imasus-dark-green/30">
        <%= t(".hero.log_in") %>
      </a>
    </div>
  </section>

  <%# Workshops %>
  <section id="workshops" class="mt-20">
    <h2 class="text-2xl font-bold tracking-tight text-imasus-dark-green sm:text-3xl">
      <%= t(".workshops.heading") %>
    </h2>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-imasus-dark-green/60">
      <%= t(".workshops.lead") %>
    </p>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% @workshops.each do |workshop| %>
        <article data-workshop-card data-slug="<%= workshop.slug %>"
                 class="flex flex-col rounded-2xl border border-imasus-dark-green/10 bg-white p-6">
          <h3 class="text-lg font-bold text-imasus-dark-green">
            <%= link_to workshop.title, workshop_path(workshop), class: "hover:underline" %>
          </h3>
          <p class="mt-1 text-xs font-medium uppercase tracking-wide text-imasus-dark-green/50">
            <%= workshop.location %>
          </p>
          <% if workshop.starts_on.present? %>
            <p class="mt-2 text-xs text-imasus-dark-green/60">
              <%= l(workshop.starts_on, format: :long) %>
              <% if workshop.ends_on.present? && workshop.ends_on != workshop.starts_on %>
                – <%= l(workshop.ends_on, format: :long) %>
              <% end %>
            </p>
          <% end %>
          <% if workshop.description.present? %>
            <p class="mt-3 text-sm leading-relaxed text-imasus-dark-green/70 line-clamp-4">
              <%= workshop.description %>
            </p>
          <% end %>

          <div class="mt-4 flex flex-wrap gap-2">
            <%= link_to workshop_path(workshop),
                        class: "inline-flex items-center rounded-full border border-imasus-dark-green/15 px-3 py-1.5 text-xs font-bold text-imasus-dark-green transition hover:border-imasus-dark-green/30" do %>
              <%= t(".workshops.see_workshop") %>
            <% end %>
            <% if workshop.contact_email.present? %>
              <%# TODO(request-a-spot): consider replacing with a real form scoped to this workshop. %>
              <a href="mailto:<%= workshop.contact_email %>"
                 class="inline-flex items-center rounded-full bg-imasus-mint px-3 py-1.5 text-xs font-bold text-imasus-dark-green transition hover:brightness-95">
                <%= t(".workshops.request_spot") %>
              </a>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </section>

  <%# Featured published projects %>
  <section class="mt-20">
    <h2 class="text-2xl font-bold tracking-tight text-imasus-dark-green sm:text-3xl">
      <%= t(".featured_projects.heading") %>
    </h2>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-imasus-dark-green/60">
      <%= t(".featured_projects.lead") %>
    </p>

    <% if @featured_projects.any? %>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% @featured_projects.each do |project| %>
          <%= link_to published_project_path(slug: project.slug),
                      data: { featured_project: true },
                      class: "group flex flex-col rounded-2xl border border-imasus-dark-green/10 bg-white p-6 transition hover:border-imasus-dark-green/30" do %>
            <h3 class="text-base font-bold text-imasus-dark-green group-hover:underline">
              <%= project.title %>
            </h3>
            <% if project.workshop %>
              <p class="mt-1 text-xs font-medium uppercase tracking-wide text-imasus-dark-green/50">
                <%= project.workshop.title %>
              </p>
            <% end %>
            <% if project.publication_updated_at %>
              <p class="mt-2 text-xs text-imasus-dark-green/50">
                <%= l(project.publication_updated_at.to_date, format: :long) %>
              </p>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div data-featured-projects-empty
           class="mt-8 rounded-2xl border border-dashed border-imasus-dark-green/15 bg-white px-6 py-10 text-sm leading-relaxed text-imasus-dark-green/60">
        <%= t(".featured_projects.empty") %>
      </div>
    <% end %>
  </section>

  <%# Public resources teaser %>
  <section class="mt-20">
    <h2 class="text-2xl font-bold tracking-tight text-imasus-dark-green sm:text-3xl">
      <%= t(".resources.heading") %>
    </h2>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <%= link_to materials_path, data: { resource_card: true, resource: "materials" },
                  class: "rounded-2xl border border-imasus-dark-green/10 bg-imasus-light-blue/30 p-5 transition hover:bg-imasus-light-blue/50" do %>
        <p class="text-xs font-medium uppercase tracking-wide text-imasus-dark-green/50">02</p>
        <h3 class="mt-2 text-base font-bold text-imasus-dark-green"><%= t(".resources.materials.title") %></h3>
        <p class="mt-2 text-xs leading-relaxed text-imasus-dark-green/70"><%= t(".resources.materials.lead") %></p>
      <% end %>
      <%= link_to training_index_path, data: { resource_card: true, resource: "training" },
                  class: "rounded-2xl border border-imasus-navy/10 bg-imasus-navy p-5 text-white transition hover:brightness-110" do %>
        <p class="text-xs font-medium uppercase tracking-wide text-white/60">03</p>
        <h3 class="mt-2 text-base font-bold"><%= t(".resources.training.title") %></h3>
        <p class="mt-2 text-xs leading-relaxed text-white/70"><%= t(".resources.training.lead") %></p>
      <% end %>
      <%= link_to challenges_path, data: { resource_card: true, resource: "challenges" },
                  class: "rounded-2xl border border-imasus-dark-green/10 bg-imasus-mint/40 p-5 transition hover:bg-imasus-mint/60" do %>
        <p class="text-xs font-medium uppercase tracking-wide text-imasus-dark-green/50">04</p>
        <h3 class="mt-2 text-base font-bold text-imasus-dark-green"><%= t(".resources.challenges.title") %></h3>
        <p class="mt-2 text-xs leading-relaxed text-imasus-dark-green/70"><%= t(".resources.challenges.lead") %></p>
      <% end %>
      <%= link_to glossary_terms_path, data: { resource_card: true, resource: "glossary" },
                  class: "rounded-2xl border border-imasus-dark-green/10 bg-imasus-light-pink/40 p-5 transition hover:bg-imasus-light-pink/60" do %>
        <p class="text-xs font-medium uppercase tracking-wide text-imasus-dark-green/50">05</p>
        <h3 class="mt-2 text-base font-bold text-imasus-dark-green"><%= t(".resources.glossary.title") %></h3>
        <p class="mt-2 text-xs leading-relaxed text-imasus-dark-green/70"><%= t(".resources.glossary.lead") %></p>
      <% end %>
    </div>
  </section>
</div>
