<div data-home-variant="participant" class="px-6 py-12 sm:px-10 lg:px-16">
  <h1 class="text-3xl font-bold tracking-tight text-imasus-dark-green sm:text-4xl">
    <%= t(".greeting", name: current_user.name) %>
  </h1>

  <% if @projects.any? %>
    <%# Project cards (journey-state) %>
    <section class="mt-10">
      <h2 class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
        <%= t(".projects.heading") %>
      </h2>

      <div class="mt-4 grid gap-5 lg:grid-cols-2">
        <% @projects.each do |project| %>
          <%= render "home/project_card", project: project %>
        <% end %>
      </div>
    </section>
    <%
      bookmark_dot_color = {
        "TrainingModule" => "bg-imasus-navy",
        "Material"       => "bg-imasus-light-blue",
        "Challenge"      => "bg-imasus-mint",
        "GlossaryTerm"   => "bg-imasus-light-pink"
      }
    %>
    <% if @recent_bookmarks.any? %>
      <section class="mt-12" data-home-section="bookmarks">
        <div class="rounded-2xl border border-imasus-dark-green/10 bg-white px-5 py-4 shadow-sm">
          <div class="flex items-center justify-between">
            <h2 class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
              <%= t(".bookmarks.heading") %>
            </h2>
            <%= link_to t(".bookmarks.see_all"), bookmarks_path,
                  class: "text-xs font-medium text-imasus-dark-green/60 hover:text-imasus-dark-green" %>
          </div>
          <ul class="mt-3 divide-y divide-imasus-dark-green/5">
            <% @recent_bookmarks.each do |bookmark| %>
              <li class="flex items-center gap-3 py-2">
                <span class="mt-px h-2 w-2 shrink-0 rounded-full <%= bookmark_dot_color.fetch(bookmark.bookmarkable_type, "bg-imasus-dark-green/20") %>"
                      title="<%= bookmark.bookmarkable_type.underscore.humanize %>"></span>
                <%= link_to bookmark.label, bookmark.url,
                      class: "min-w-0 flex-1 truncate text-sm font-medium text-imasus-dark-green hover:underline" %>
              </li>
            <% end %>
          </ul>
        </div>
      </section>
    <% end %>

    <% if @workshops.any? %>
      <section class="mt-12">
        <h2 class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
          <%= t(".workshops.heading") %>
        </h2>
        <%= render "home/workshop_strip", workshops: @workshops %>
      </section>
    <% end %>
  <% elsif @workshops.any? %>
    <%# Empty state — has workshops, no projects: foreground workshops %>
    <section data-empty-state="no-projects" class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-imasus-dark-green sm:text-2xl">
        <%= t(".empty_no_projects.heading") %>
      </h2>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-imasus-dark-green/60">
        <%= t(".empty_no_projects.lead") %>
      </p>
      <%= render "home/workshop_strip", workshops: @workshops %>
    </section>
  <% else %>
    <%# Empty state — no workshops at all (rare) %>
    <section data-empty-state="no-workshops" class="mt-10 rounded-2xl border border-dashed border-imasus-dark-green/15 bg-white px-6 py-10">
      <p class="text-sm leading-relaxed text-imasus-dark-green/60">
        <%= t(".empty_no_workshops") %>
      </p>
    </section>
  <% end %>

  <%# Public resources teaser — same styled grid as the visitor home %>
  <section class="mt-16">
    <h2 class="text-xs font-bold uppercase tracking-widest text-imasus-dark-green/50">
      <%= t(".resources.heading") %>
    </h2>
    <div class="mt-4">
      <%= render "shared/resources_grid" %>
    </div>
  </section>
</div>
