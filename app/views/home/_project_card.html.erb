<%# Locals: project (Project).
    Renders one card per participant project with journey-state CTAs:
    - draft + 0 logs → primary "Add your first log entry"
    - draft + 1+ logs → primary "Continue your log", secondary "Publish"
    - published → primary "View public page", secondary "Edit publication" %>
<% log_count = project.log_entries.size %>
<article data-project-card data-project-id="<%= project.id %>"
         class="flex flex-col rounded-2xl border border-imasus-dark-green/10 bg-white p-5">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-lg font-bold text-imasus-dark-green">
        <%= link_to project.title, project_path(project), class: "hover:underline" %>
      </h3>
      <% if project.workshop %>
        <p class="mt-1 text-xs font-medium uppercase tracking-wide text-imasus-dark-green/50">
          <%= project.workshop.title %>
        </p>
      <% end %>
    </div>
    <span class="<%= project.published? ? 'bg-imasus-mint/40' : 'bg-imasus-light-blue/40' %>
                 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-bold text-imasus-dark-green">
      <%= t("home.participant.status.#{project.published? ? 'published' : 'draft'}") %>
    </span>
  </div>

  <% if project.challenge %>
    <p class="mt-2 text-xs text-imasus-dark-green/60">
      <%= project.challenge.code %>
    </p>
  <% end %>

  <% if project.members.any? %>
    <p class="mt-2 text-xs text-imasus-dark-green/60">
      <%= project.members.map { |m| m.name.split.map(&:first).join.upcase }.join(" · ") %>
    </p>
  <% end %>

  <p class="mt-3 text-xs text-imasus-dark-green/50">
    <%= t("home.participant.last_activity",
          time: time_ago_in_words(project.updated_at)) %>
  </p>

  <div class="mt-4 flex flex-wrap gap-2">
    <% if project.published? %>
      <%= link_to published_project_path(slug: project.slug),
                  class: "inline-flex items-center rounded-full bg-imasus-dark-green px-3 py-1.5 text-xs font-bold text-white transition hover:bg-imasus-navy" do %>
        <%= t("home.participant.cta.view_public") %>
      <% end %>
      <%= link_to edit_project_publication_path(project),
                  class: "inline-flex items-center rounded-full border border-imasus-dark-green/15 px-3 py-1.5 text-xs font-bold text-imasus-dark-green transition hover:border-imasus-dark-green/30" do %>
        <%= t("home.participant.cta.edit_publication") %>
      <% end %>
    <% elsif log_count.positive? %>
      <%= link_to project_log_entries_path(project),
                  class: "inline-flex items-center rounded-full bg-imasus-dark-green px-3 py-1.5 text-xs font-bold text-white transition hover:bg-imasus-navy" do %>
        <%= t("home.participant.cta.continue_log") %>
      <% end %>
      <%= link_to new_project_publication_path(project),
                  class: "inline-flex items-center rounded-full border border-imasus-dark-green/15 px-3 py-1.5 text-xs font-bold text-imasus-dark-green transition hover:border-imasus-dark-green/30" do %>
        <%= t("home.participant.cta.publish") %>
      <% end %>
    <% else %>
      <%= link_to new_project_log_entry_path(project),
                  class: "inline-flex items-center rounded-full bg-imasus-dark-green px-3 py-1.5 text-xs font-bold text-white transition hover:bg-imasus-navy" do %>
        <%= t("home.participant.cta.add_first_log_entry") %>
      <% end %>
      <%= link_to project_path(project),
                  class: "inline-flex items-center rounded-full border border-imasus-dark-green/15 px-3 py-1.5 text-xs font-bold text-imasus-dark-green transition hover:border-imasus-dark-green/30" do %>
        <%= t("home.participant.cta.open_project") %>
      <% end %>
    <% end %>
  </div>
</article>
