#!/bin/bash -e

# If running the rails server then create or migrate existing database.
# Fly deploys run this once through the release_command instead.
if [ "${SKIP_DB_PREPARE_ON_BOOT}" != "true" ] && [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
